---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Julie Wright Realty Group | Triangle Area Real Estate',
  description = 'Four decades specializing in Triangle Area properties. Your comprehensive real estate resource for Wake, Granville, Franklin, Johnston, Harnett, and Durham Counties.',
} = Astro.props;

interface NavItem {
  label: string;
  href: string;
  children?: { label: string; href: string }[];
}

const navLinks: NavItem[] = [
  {
    label: 'Listings',
    href: '/listings',
    children: [
      { label: 'Search MLS', href: '/property-search' },
      { label: 'Our Properties', href: '/listings' },
      { label: 'Property Organizer', href: '/property-organizer' },
      { label: 'Neighborhoods', href: '/neighborhoods' },
      { label: 'Neighborhood Map', href: '/neighborhood-map' },
    ],
  },
  {
    label: 'Buyers',
    href: '/buyers',
    children: [
      { label: 'Buyer Resources', href: '/buyers' },
      { label: 'Real Estate 101', href: '/buyers/real-estate-101' },
      { label: 'Buyer FAQs', href: '/buyers/faq' },
      { label: 'Mortgage Calculator', href: '/buyers/mortgage-calculator' },
      { label: 'Free Buying Guide', href: '/buyers/buying-guide' },
    ],
  },
  {
    label: 'Sellers',
    href: '/sellers',
    children: [
      { label: 'Seller Resources', href: '/sellers' },
      { label: 'Staging Tips', href: '/sellers/staging-tips' },
      { label: 'Home Value', href: '/sellers/home-value' },
      { label: 'List Your Property', href: '/sellers/list-your-property' },
      { label: 'Neighborhood Sold Report', href: '/sellers/neighborhood-sold-report' },
    ],
  },
  {
    label: 'Relocation',
    href: '/relocation',
    children: [
      { label: 'Relocation Resources', href: '/relocation' },
      { label: 'Free Relocation Package', href: '/relocation/relocation-package' },
      { label: 'Moving Tips', href: '/relocation/moving-tips' },
    ],
  },
  {
    label: 'About',
    href: '/about',
    children: [
      { label: 'Our History', href: '/about' },
      { label: 'Our Team', href: '/about/team' },
      { label: 'Triangle Area', href: '/about/triangle-area' },
      { label: 'Business Directory', href: '/about/business-directory' },
      { label: 'Testimonials', href: '/testimonials' },
    ],
  },
  { label: 'Contact', href: '/contact' },
];
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="bg-warm-50 text-navy-900 font-sans antialiased">
    <!-- Header -->
    <header
      id="site-header"
      class="fixed top-0 left-0 right-0 z-50 transition-all duration-500"
    >
      <!-- Top bar -->
      <div class="bg-navy-900/95 backdrop-blur-sm text-white/80 text-sm hidden lg:block">
        <div class="max-w-7xl mx-auto px-6 py-2 flex justify-between items-center">
          <div class="flex items-center gap-6">
            <a href="tel:919-847-7140" class="hover:text-gold-400 transition-colors flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              (919) 847-7140
            </a>
            <a href="mailto:info@juliewrightrealtygroup.com" class="hover:text-gold-400 transition-colors flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              info@juliewrightrealtygroup.com
            </a>
          </div>
          <div class="flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            10931 Strickland Rd, Ste 111, Raleigh, NC 27615
          </div>
        </div>
      </div>

      <!-- Main nav -->
      <nav class="bg-white/95 backdrop-blur-md shadow-sm border-b border-warm-200/50 transition-all duration-500" id="main-nav">
        <div class="max-w-7xl mx-auto px-6 flex items-center justify-between h-20">
          <!-- Logo -->
          <a href="/" class="flex items-center gap-3 group">
            <img
              src="https://reappdata.global.ssl.fastly.net/site_data/baileywrightrealty/design_assets/8d72jwrg-1.png"
              alt="Julie Wright Realty Group"
              class="h-14 w-auto"
            />
            <div class="hidden sm:block">
              <div class="text-navy-900 font-serif text-lg font-semibold leading-tight group-hover:text-gold-600 transition-colors">
                Julie Wright
              </div>
              <div class="text-navy-500 text-xs tracking-widest uppercase">
                Realty Group
              </div>
            </div>
          </a>

          <!-- Desktop Nav -->
          <div class="hidden lg:flex items-center gap-1">
            {navLinks.map(link => (
              link.children ? (
                <div class="relative group">
                  <a
                    href={link.href}
                    class="px-4 py-2 text-sm font-medium tracking-wide text-navy-700 hover:text-gold-600 transition-colors flex items-center gap-1 relative after:absolute after:bottom-0 after:left-1/2 after:-translate-x-1/2 after:w-0 group-hover:after:w-6 after:h-0.5 after:bg-gold-500 after:transition-all after:duration-300"
                  >
                    {link.label}
                    <svg class="w-3 h-3 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                  </a>
                  <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                    <div class="bg-white rounded-xl shadow-xl shadow-navy-900/10 border border-warm-200/50 py-2 min-w-[240px]">
                      {link.children.map(child => (
                        <a
                          href={child.href}
                          class="block px-5 py-2.5 text-sm text-navy-700 hover:text-gold-600 hover:bg-warm-50 transition-colors"
                        >
                          {child.label}
                        </a>
                      ))}
                    </div>
                  </div>
                </div>
              ) : (
                <a
                  href={link.href}
                  class="px-4 py-2 text-sm font-medium tracking-wide text-navy-700 hover:text-gold-600 transition-colors relative after:absolute after:bottom-0 after:left-1/2 after:-translate-x-1/2 after:w-0 hover:after:w-6 after:h-0.5 after:bg-gold-500 after:transition-all after:duration-300"
                >
                  {link.label}
                </a>
              )
            ))}
            <a
              href="/contact"
              class="ml-4 px-6 py-2.5 bg-gold-500 hover:bg-gold-600 text-white text-sm font-semibold tracking-wide rounded transition-all duration-300 hover:shadow-lg hover:shadow-gold-500/25"
            >
              Get in Touch
            </a>
          </div>

          <!-- Mobile menu button -->
          <button
            id="mobile-menu-btn"
            class="lg:hidden p-2 text-navy-700 hover:text-gold-600 transition-colors"
            aria-label="Toggle menu"
          >
            <svg class="w-6 h-6" id="menu-open-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg class="w-6 h-6 hidden" id="menu-close-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <!-- Mobile Nav -->
        <div id="mobile-menu" class="lg:hidden hidden bg-white border-t border-warm-200/50 max-h-[calc(100vh-5rem)] overflow-y-auto">
          <div class="px-6 py-4 space-y-1">
            {navLinks.map(link => (
              link.children ? (
                <details class="group">
                  <summary class="cursor-pointer flex items-center justify-between px-4 py-3 text-navy-700 hover:text-gold-600 hover:bg-warm-50 rounded-lg transition-colors font-medium list-none">
                    <span>{link.label}</span>
                    <svg class="w-4 h-4 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                  </summary>
                  <div class="pl-4 mt-1 space-y-1">
                    {link.children.map(child => (
                      <a href={child.href} class="block px-4 py-2 text-sm text-navy-600 hover:text-gold-600 hover:bg-warm-50 rounded-lg transition-colors">
                        {child.label}
                      </a>
                    ))}
                  </div>
                </details>
              ) : (
                <a
                  href={link.href}
                  class="block px-4 py-3 text-navy-700 hover:text-gold-600 hover:bg-warm-50 rounded-lg transition-colors font-medium"
                >
                  {link.label}
                </a>
              )
            ))}
            <div class="pt-3">
              <a
                href="/contact"
                class="block text-center px-6 py-3 bg-gold-500 hover:bg-gold-600 text-white font-semibold rounded-lg transition-colors"
              >
                Get in Touch
              </a>
            </div>
            <div class="pt-3 border-t border-warm-200 mt-3">
              <a href="tel:919-847-7140" class="block px-4 py-2 text-sm text-navy-500">(919) 847-7140</a>
              <a href="mailto:info@juliewrightrealtygroup.com" class="block px-4 py-2 text-sm text-navy-500">info@juliewrightrealtygroup.com</a>
            </div>
          </div>
        </div>
      </nav>
    </header>

    <!-- Main Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-navy-900 text-white">
      <!-- Main footer -->
      <div class="max-w-7xl mx-auto px-6 py-16">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
          <!-- Brand -->
          <div class="lg:col-span-1">
            <a href="/" class="inline-block mb-5">
              <img
                src="https://reappdata.global.ssl.fastly.net/site_data/baileywrightrealty/design_assets/8d72jwrg-1.png"
                alt="Julie Wright Realty Group"
                class="h-16 w-auto brightness-0 invert opacity-90"
              />
            </a>
            <p class="text-navy-300 text-sm leading-relaxed">
              Four decades specializing in Triangle Area properties. Your trusted partner for real estate in Wake, Granville, Franklin, Johnston, Harnett, and Durham Counties.
            </p>
          </div>

          <!-- Quick Links -->
          <div>
            <h3 class="text-gold-400 font-semibold text-sm tracking-widest uppercase mb-5">Quick Links</h3>
            <ul class="space-y-3">
              <li><a href="/listings" class="text-navy-300 hover:text-gold-400 transition-colors text-sm">Featured Listings</a></li>
              <li><a href="/buyers" class="text-navy-300 hover:text-gold-400 transition-colors text-sm">Buyer Resources</a></li>
              <li><a href="/sellers" class="text-navy-300 hover:text-gold-400 transition-colors text-sm">Seller Resources</a></li>
              <li><a href="/relocation" class="text-navy-300 hover:text-gold-400 transition-colors text-sm">Relocation</a></li>
              <li><a href="/about" class="text-navy-300 hover:text-gold-400 transition-colors text-sm">About Us</a></li>
            </ul>
          </div>

          <!-- Resources -->
          <div>
            <h3 class="text-gold-400 font-semibold text-sm tracking-widest uppercase mb-5">Resources</h3>
            <ul class="space-y-3">
              <li><a href="/neighborhoods" class="text-navy-300 hover:text-gold-400 transition-colors text-sm">Neighborhoods</a></li>
              <li><a href="/buyers/mortgage-calculator" class="text-navy-300 hover:text-gold-400 transition-colors text-sm">Mortgage Calculator</a></li>
              <li><a href="/sellers/staging-tips" class="text-navy-300 hover:text-gold-400 transition-colors text-sm">Home Staging Tips</a></li>
              <li><a href="/sellers/home-value" class="text-navy-300 hover:text-gold-400 transition-colors text-sm">Home Valuation</a></li>
              <li><a href="/buyers/faq" class="text-navy-300 hover:text-gold-400 transition-colors text-sm">FAQ</a></li>
            </ul>
          </div>

          <!-- Contact -->
          <div>
            <h3 class="text-gold-400 font-semibold text-sm tracking-widest uppercase mb-5">Contact Us</h3>
            <ul class="space-y-3 text-sm text-navy-300">
              <li class="flex items-start gap-3">
                <svg class="w-4 h-4 mt-0.5 text-gold-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                <span>10931 Strickland Rd<br />Ste 111<br />Raleigh, NC 27615</span>
              </li>
              <li class="flex items-center gap-3">
                <svg class="w-4 h-4 text-gold-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                <a href="tel:919-847-7140" class="hover:text-gold-400 transition-colors">(919) 847-7140</a>
              </li>
              <li class="flex items-center gap-3">
                <svg class="w-4 h-4 text-gold-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                <a href="mailto:info@juliewrightrealtygroup.com" class="hover:text-gold-400 transition-colors">info@juliewrightrealtygroup.com</a>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Bottom bar -->
      <div class="border-t border-navy-800">
        <div class="max-w-7xl mx-auto px-6 py-6 flex flex-col sm:flex-row justify-between items-center gap-4">
          <div class="flex items-center gap-4">
            <img
              src="https://reappdata.global.ssl.fastly.net/lib/realestate_solution/layouts/artisan/images/logo-realtor.png"
              alt="Realtor"
              class="h-6 brightness-0 invert opacity-60"
            />
            <img
              src="https://reappdata.global.ssl.fastly.net/lib/realestate_solution/layouts/artisan/images/logo-eho.png"
              alt="Equal Housing Opportunity"
              class="h-6 brightness-0 invert opacity-60"
            />
          </div>
          <p class="text-navy-400 text-xs text-center">
            &copy; {new Date().getFullYear()} Julie Wright Realty Group. All rights reserved. Information deemed reliable, but not guaranteed.
          </p>
          <div class="flex gap-4 text-xs">
            <a href="/privacy" class="text-navy-400 hover:text-gold-400 transition-colors">Privacy Policy</a>
            <a href="/accessibility" class="text-navy-400 hover:text-gold-400 transition-colors">Accessibility</a>
          </div>
        </div>
      </div>
    </footer>

    <script>
      // Mobile menu toggle
      const menuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const openIcon = document.getElementById('menu-open-icon');
      const closeIcon = document.getElementById('menu-close-icon');

      menuBtn?.addEventListener('click', () => {
        const isOpen = !mobileMenu?.classList.contains('hidden');
        mobileMenu?.classList.toggle('hidden');
        openIcon?.classList.toggle('hidden');
        closeIcon?.classList.toggle('hidden');
      });

      // Header scroll effect
      const header = document.getElementById('site-header');
      let lastScroll = 0;

      window.addEventListener('scroll', () => {
        const currentScroll = window.scrollY;

        if (currentScroll > 100) {
          header?.classList.add('header-scrolled');
        } else {
          header?.classList.remove('header-scrolled');
        }

        lastScroll = currentScroll;
      });
    </script>

    <style>
      @reference "../styles/global.css";
      .header-scrolled #main-nav {
        @apply shadow-md;
      }
    </style>
  </body>
</html>
