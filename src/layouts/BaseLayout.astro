---
import '../styles/global.css';
import FontSwitcher from '../components/FontSwitcher.astro';
import { site } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = `${site.name} | Triangle Area Real Estate`,
  description = site.description,
  image,
} = Astro.props;

const currentPath = Astro.url.pathname;
const canonicalUrl = `${Astro.url.origin}${Astro.url.pathname}`;

// Social share image. Pages pass a root-relative path or an absolute URL
// (listing detail passes the listing's primary photo); both are resolved to an
// absolute URL because social crawlers reject relative paths. Falls back to the
// branded 1200×630 card. Rename the default file (not just its contents) to bust
// LinkedIn's ~7-day preview cache.
const DEFAULT_OG_IMAGE = '/images/og-default.png';
const ogImageUrl = new URL(image ?? DEFAULT_OG_IMAGE, Astro.site ?? Astro.url).href;

// Flat top-level nav — deeper pages are reached from each section landing page.
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/listings', label: 'Listings' },
  { href: '/buyers', label: 'Buyers' },
  { href: '/sellers', label: 'Sellers' },
  { href: '/relocation', label: 'Relocation' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];

const footerNav = [
  { href: '/listings', label: 'Listings' },
  { href: '/property-search', label: 'Search MLS' },
  { href: '/neighborhoods', label: 'Neighborhoods' },
  { href: '/buyers', label: 'Buyers' },
  { href: '/sellers', label: 'Sellers' },
  { href: '/relocation', label: 'Relocation' },
  { href: '/about', label: 'About' },
  { href: '/about/team', label: 'Our Team' },
  { href: '/testimonials', label: 'Testimonials' },
  { href: '/contact', label: 'Contact' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/JWRG_Icon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Gabarito:wght@400..900&family=Anek+Latin:ital,wght@0,100..800;1,100..800&display=swap" rel="stylesheet" />
  </head>
  <body class="site-body">
    <!-- Skip to main content -->
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <!-- Global topo background overlay -->
    <div class="topo-bg-wrap-fixed">
      <img src="/FallTopo_v2.svg" class="topo-bg" alt="" aria-hidden="true" />
    </div>

    <!-- Navigation -->
    <header class="site-header" id="site-header">
      <div class="header-bg" id="header-bg"></div>
      <nav class="site-nav" aria-label="Primary navigation">
        <!-- Logo (left) -->
        <a href="/" class="nav-logo">
          <div class="nav-logo-icon" role="img" aria-label={site.name}></div>
        </a>

        <!-- Desktop Nav (center) -->
        <ul class="nav-desktop">
          {navLinks.map((link) => {
            const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
            return (
              <li>
                <a
                  href={link.href}
                  class:list={[
                    'nav-desktop-link',
                    isActive ? 'nav-link-active' : 'nav-link-inactive',
                  ]}
                  aria-current={isActive ? 'page' : undefined}
                >
                  <span class="nav-link-bg" aria-hidden="true"></span>
                  {link.label}
                  {isActive && <span class="nav-active-bar" />}
                </a>
              </li>
            );
          })}
        </ul>

        <!-- Desktop search (deep-links into the /listings keyword filter) -->
        <form action="/listings" method="get" role="search" class="ml-auto hidden lg:block">
          <label for="nav-search" class="sr-only">Search listings</label>
          <div class="relative">
            <svg class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-earth-50/70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input id="nav-search" name="q" type="search" placeholder="Search listings…" class="w-44 focus:w-60 rounded-full border border-earth-50/30 bg-earth-50/10 py-1.5 pl-9 pr-3 text-sm text-earth-50 placeholder:text-earth-50/60 focus:outline-none focus:border-earth-50/60 focus:bg-earth-50/15 transition-all duration-300" />
          </div>
        </form>

        <!-- Mobile Menu Button -->
        <button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="Toggle navigation menu" aria-expanded="false" aria-controls="mobile-menu">
          <span class="sr-only">Menu</span>
          <div class="hamburger-wrap" aria-hidden="true">
            <span class="hamburger-bar" id="bar1"></span>
            <span class="hamburger-bar" id="bar2"></span>
            <span class="hamburger-bar" id="bar3"></span>
          </div>
        </button>
      </nav>

      <!-- Mobile Menu -->
      <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
        <form action="/listings" method="get" role="search" class="px-4 pt-3 pb-1">
          <label for="nav-search-mobile" class="sr-only">Search listings</label>
          <div class="relative">
            <svg class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-earth-50/70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input id="nav-search-mobile" name="q" type="search" placeholder="Search listings…" class="w-full rounded-full border border-earth-50/30 bg-earth-50/10 py-2 pl-9 pr-3 text-sm text-earth-50 placeholder:text-earth-50/60 focus:outline-none focus:border-earth-50/60 transition-colors" />
          </div>
        </form>
        <ul class="mobile-menu-list">
          {navLinks.map((link) => {
            const isActive = currentPath === link.href;
            return (
              <li>
                <a
                  href={link.href}
                  class:list={[
                    'mobile-menu-link',
                    isActive ? 'nav-link-active' : 'nav-link-inactive',
                  ]}
                  aria-current={isActive ? 'page' : undefined}
                >
                  {link.label}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    </header>

    <FontSwitcher />

    <!-- Main Content -->
    <main class="site-main" id="main-content">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="site-footer">
      <img src="/FallTopo_v2.svg" class="topo-bg topo-bg--faint" alt="" aria-hidden="true" />
      <div class="footer-inner">
        <div class="footer-grid">
          <!-- Brand -->
          <div class="footer-brand">
            <a href="/" class="footer-logo">
              <img src="/JWRG_Full_White.svg" class="footer-logo-img" alt={site.name} />
            </a>
            <p class="footer-tagline">
              Four decades guiding Triangle-area families home — full-service residential real estate
              across Wake, Granville, Franklin, Johnston, Harnett, and Durham counties.
            </p>
          </div>

          <!-- Quick Links -->
          <nav aria-label="Footer navigation">
            <h4 class="footer-col-heading">Navigate</h4>
            <ul class="footer-nav-list">
              {footerNav.map((link) => (
                <li>
                  <a href={link.href} class="footer-nav-link">{link.label}</a>
                </li>
              ))}
            </ul>
          </nav>

          <!-- Services -->
          <div>
            <h4 class="footer-col-heading">How We Help</h4>
            <ul class="footer-services-list">
              <li>Buying a Home</li>
              <li>Selling a Home</li>
              <li>Relocation Services</li>
              <li>New Construction</li>
              <li>Neighborhood Expertise</li>
              <li>Market & Home Valuations</li>
            </ul>
          </div>

          <!-- Contact -->
          <div>
            <h4 class="footer-col-heading">Contact</h4>
            <address class="footer-contact">
              <p>{site.address.street1}{site.address.street2 ? `, ${site.address.street2}` : ''}<br />{site.address.city}, {site.address.state} {site.address.zip}</p>
              <p>
                <a href={`tel:${site.phoneRaw}`} class="footer-contact-link">{site.phone}</a>
              </p>
              <p>
                <a href={`mailto:${site.email}`} class="footer-contact-link">{site.email}</a>
              </p>
            </address>
          </div>
        </div>

        <!-- Affiliations / compliance marks -->
        <div class="footer-affiliations">
          <span class="footer-affiliation">
            <svg class="footer-affiliation-mark" viewBox="0 0 64 64" role="img" aria-labelledby="eho-title">
              <title id="eho-title">Equal Housing Opportunity</title>
              <path d="M9 31 L32 11 L55 31" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linejoin="round" stroke-linecap="round" />
              <path d="M15 28 V54 H49 V28" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linejoin="round" />
              <rect x="23" y="34" width="18" height="4.5" fill="currentColor" />
              <rect x="23" y="43" width="18" height="4.5" fill="currentColor" />
            </svg>
            <span class="footer-affiliation-label">Equal Housing Opportunity</span>
          </span>
          <!-- Official REALTOR® membership mark (white version, used as-is per
               NAR Membership Marks rules). Source files live in jw-design-guide
               (public/affiliations/realtor/). -->
          <span class="footer-affiliation">
            <img src="/affiliations/realtor-logo-white.png" class="footer-affiliation-mark" alt="REALTOR&reg;" width="600" height="600" />
          </span>
        </div>

        <div class="footer-bottom">
          <p class="footer-copyright">&copy; {new Date().getFullYear()} {site.name}. All rights reserved.</p>
          <p class="footer-location">Raleigh, NC &middot; Serving the Triangle for 40+ Years</p>
        </div>
      </div>
    </footer>

    <script>
      import { captureSource } from '../lib/source';

      // Stash ref/utm_* landing params for form-submission attribution.
      captureSource();

      // Topo width — zoom-independent
      // outerWidth is in layout pixels (unaffected by zoom); innerWidth is in CSS pixels (zoom-dependent).
      // We size the SVG in layout pixels, then convert to CSS pixels so it stays physically constant.
      function updateTopoWidth() {
        const outer = window.outerWidth;
        const inner = window.innerWidth;
        const physicalW = Math.max(2160, outer / 0.95); // layout pixels
        const cssW = physicalW * inner / outer;          // convert to CSS pixels
        document.documentElement.style.setProperty('--topo-width', `${Math.round(cssW)}px`);
      }
      let resizeTimer: ReturnType<typeof setTimeout> | null = null;
      function scheduleResize() {
        if (!resizeTimer) {
          document.querySelectorAll<HTMLElement>('.topo-bg').forEach(el => el.style.visibility = 'hidden');
        }
        clearTimeout(resizeTimer!);
        resizeTimer = setTimeout(() => {
          updateTopoWidth();
          updateParallax();
          document.querySelectorAll<HTMLElement>('.topo-bg').forEach(el => el.style.visibility = '');
          resizeTimer = null;
        }, 150);
      }

      updateTopoWidth();
      window.addEventListener('resize', scheduleResize);

      // Topo SVG parallax — seamless across sections, scrolls slower than page
      const PARALLAX_SPEED = 0.3; // fraction of scroll speed (0 = with page, 1 = fixed to viewport)
      function updateParallax() {
        const scrollY = window.scrollY;
        const vpH = window.innerHeight;
        const elements = document.querySelectorAll<HTMLElement>('.topo-bg');
        if (!elements.length) return;

        const svgHeight = elements[0].offsetHeight;

        // Raw target: SVG center drifts upward at PARALLAX_SPEED as page scrolls
        const rawTargetVpY = vpH / 2 - scrollY * PARALLAX_SPEED;

        // Clamp so SVG edges never become visible:
        //   top edge clamped: targetVpY <= svgHeight / 2
        //   bottom edge clamped: targetVpY >= vpH - svgHeight / 2
        const targetVpY = Math.max(vpH - svgHeight / 2, Math.min(svgHeight / 2, rawTargetVpY));

        elements.forEach(el => {
          const section = el.parentElement;
          if (!section) return;
          const rect = section.getBoundingClientRect();
          const sectionCenterVpY = rect.top + rect.height / 2;
          const offset = targetVpY - sectionCenterVpY;
          el.style.transform = `translateX(-50%) translateY(calc(-50% + ${offset}px))`;
        });
      }

      let rafPending = false;
      function scheduleParallax() {
        if (!rafPending) {
          rafPending = true;
          requestAnimationFrame(() => { updateParallax(); rafPending = false; });
        }
      }

      updateParallax();
      window.addEventListener('scroll', scheduleParallax, { passive: true });

      // Nav click animations
      document.querySelectorAll<HTMLAnchorElement>('.nav-desktop-link').forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();

          // Deactivate current active link
          const activeLink = document.querySelector<HTMLElement>('.nav-link-active');
          if (activeLink && activeLink !== link) {
            activeLink.classList.add('nav-link-deactivating');
          }

          // Drive click animation via inline styles so hover/CSS specificity can't interfere
          const bg = link.querySelector<HTMLElement>('.nav-link-bg');
          if (bg) {
            // Snap to start state (scaleY 0, gold, no transition)
            bg.style.transition = 'none';
            bg.style.backgroundColor = 'var(--color-gold-300)';
            bg.style.transform = 'scaleY(0)';
            bg.style.opacity = '1';
            // Next frame: re-enable transition and animate to full height
            requestAnimationFrame(() => {
              bg.style.transition = 'transform 100ms ease';
              bg.style.transform = 'scaleY(1)';
            });
          }

          link.classList.add('nav-link-clicking');
          setTimeout(() => { window.location.href = link.href; }, 100);
        });
      });

      // Mobile menu
      const menuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');

      menuBtn?.addEventListener('click', () => {
        const open = menuBtn.classList.toggle('open');
        mobileMenu?.classList.toggle('open', open);
        menuBtn.setAttribute('aria-expanded', String(open));
        mobileMenu?.setAttribute('aria-hidden', String(!open));
      });
    </script>
  </body>
</html>
