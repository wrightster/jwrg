---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageBanner from '../../components/PageBanner.astro';
import MiniContactForm from '../../components/MiniContactForm.astro';
import { neighborhoods } from '../../data/neighborhoods';

export const prerender = true;
---

<BaseLayout title="Neighborhoods | Julie Wright Realty Group">
  <PageBanner
    label="Explore"
    title="Triangle Area Neighborhoods and Subdivisions"
    description="A curated selection of communities offered by or familiar to Julie Wright Realty Group — from gated estate enclaves to working farms and new construction."
  />

  <section class="py-20">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {neighborhoods.map((n) => (
          <a
            href={`/neighborhoods/${n.slug}`}
            class="group bg-white border border-warm-200/50 rounded-2xl overflow-hidden hover:shadow-xl hover:shadow-navy-900/8 transition-all hover:-translate-y-1"
          >
            <div class="aspect-[4/3] bg-gradient-to-br from-warm-200 via-gold-100 to-warm-100 relative overflow-hidden">
              <div class="absolute inset-0 flex items-center justify-center">
                <svg class="w-24 h-24 text-gold-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
              </div>
              {n.status === 'coming_soon' && (
                <span class="absolute top-4 left-4 px-3 py-1 rounded-full text-xs font-semibold border bg-gold-500/90 text-white border-gold-400 backdrop-blur-sm">
                  Coming Soon
                </span>
              )}
            </div>
            <div class="p-6">
              <div class="text-gold-600 text-xs tracking-widest uppercase mb-1">{n.county}{n.city ? ` · ${n.city}` : ''}</div>
              <h3 class="font-serif text-xl font-semibold text-navy-900 group-hover:text-gold-700 transition-colors">
                {n.name}
              </h3>
              <p class="text-navy-500 text-sm mt-2 leading-relaxed line-clamp-3">{n.description}</p>
              {n.priceFrom && (
                <div class="mt-4 pt-4 border-t border-warm-200/60 text-navy-700 text-sm">
                  From <span class="font-semibold text-navy-900">{n.priceFrom}</span>
                </div>
              )}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <MiniContactForm />
</BaseLayout>
