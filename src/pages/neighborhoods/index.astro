---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageBanner from '../../components/PageBanner.astro';
import MiniContactForm from '../../components/MiniContactForm.astro';
import { fetchNeighborhoods, photoSrc } from '../../lib/api';

const neighborhoods = await fetchNeighborhoods().catch(() => []);

const statusLabels: Record<string, string> = {
  planning: 'Planning',
  under_development: 'Under Development',
  active_sales: 'Active Sales',
  sold_out: 'Sold Out',
  established: 'Established',
};
---

<BaseLayout
  title="Neighborhoods | Julie Wright Realty Group"
  description="Triangle-area communities and subdivisions curated by Julie Wright Realty Group. Photos, amenities, HOA details, schools, and current listings for each."
>
  <PageBanner
    label="Explore"
    title="Triangle Area Neighborhoods and Subdivisions"
    description="A curated selection of communities offered by or familiar to Julie Wright Realty Group — from gated estate enclaves to working farms and new construction."
  />

  <section class="py-20">
    <div class="max-w-7xl mx-auto px-6">
      {neighborhoods.length === 0 ? (
        <div class="text-center text-navy-500 py-16">
          <p>No neighborhoods are available right now. Please check back soon.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {neighborhoods.map((n) => {
            const heroSrc = photoSrc(n.primary_photo, 800);
            const location = [n.city, n.county && `${n.county} County`].filter(Boolean).join(' · ');
            return (
              <a
                href={`/neighborhoods/${n.slug}`}
                class="group bg-white border border-warm-200/50 rounded-2xl overflow-hidden hover:shadow-xl hover:shadow-navy-900/8 transition-all hover:-translate-y-1 flex flex-col"
              >
                <div class="aspect-[4/3] relative overflow-hidden">
                  {heroSrc ? (
                    <img
                      src={heroSrc}
                      alt={n.primary_photo?.alt ?? n.name}
                      class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700"
                      loading="lazy"
                    />
                  ) : (
                    <div class="w-full h-full bg-gradient-to-br from-warm-200 via-gold-100 to-warm-100 flex items-center justify-center">
                      <svg class="w-24 h-24 text-gold-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                    </div>
                  )}
                  {n.status && n.status !== 'established' && n.status !== 'active_sales' && (
                    <span class="absolute top-4 left-4 px-3 py-1 rounded-full text-xs font-semibold border bg-gold-500/90 text-white border-gold-400 backdrop-blur-sm">
                      {statusLabels[n.status]}
                    </span>
                  )}
                  {(n.listings_count ?? 0) > 0 && (
                    <span class="absolute bottom-4 right-4 px-3 py-1.5 rounded-lg text-xs font-semibold bg-navy-900/80 text-white backdrop-blur-sm">
                      {n.listings_count} listing{n.listings_count === 1 ? '' : 's'}
                    </span>
                  )}
                </div>
                <div class="p-6 flex-1 flex flex-col">
                  {location && (
                    <div class="text-gold-600 text-xs tracking-widest uppercase mb-1">{location}</div>
                  )}
                  <h3 class="font-serif text-xl font-semibold text-navy-900 group-hover:text-gold-700 transition-colors">
                    {n.name}
                  </h3>
                  <p class="text-navy-500 text-sm mt-2 leading-relaxed line-clamp-3 flex-1">
                    {n.marketing_description ?? n.description ?? `Explore ${n.name} — ${location || 'a community curated by Julie Wright Realty Group'}.`}
                  </p>
                  {(n.amenities?.length ?? 0) > 0 && (
                    <div class="mt-4 pt-4 border-t border-warm-200/60 flex flex-wrap gap-1.5">
                      {n.amenities.slice(0, 3).map((a) => (
                        <span class="text-xs px-2 py-0.5 rounded-full bg-warm-100 text-navy-700">{a}</span>
                      ))}
                      {n.amenities.length > 3 && (
                        <span class="text-xs px-2 py-0.5 text-navy-500">+ {n.amenities.length - 3} more</span>
                      )}
                    </div>
                  )}
                </div>
              </a>
            );
          })}
        </div>
      )}
    </div>
  </section>

  <MiniContactForm />
</BaseLayout>
