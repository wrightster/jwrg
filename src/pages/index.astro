---
import BaseLayout from '../layouts/BaseLayout.astro';
import ListingCard from '../components/ListingCard.astro';
import BtnArrow from '../components/BtnArrow.astro';
import { fetchListings, type ApiListing } from '../lib/api';

let apiError = false;
let featuredListings: ApiListing[] = [];
try {
  featuredListings = await fetchListings({ featured: true, perPage: 6 });
  if (featuredListings.length === 0) {
    featuredListings = (await fetchListings({ perPage: 6 }));
  }
} catch {
  apiError = true;
}

const helpLinks = [
  { href: '/buyers', label: 'Buying a Home', desc: 'Guides, financing, and a search built around how you live.' },
  { href: '/sellers', label: 'Selling a Home', desc: 'Pricing strategy, staging, and full-service marketing.' },
  { href: '/relocation', label: 'Relocating', desc: 'Moving to the Triangle? We make the landing soft.' },
  { href: '/neighborhoods', label: 'Neighborhoods', desc: 'Explore communities across six counties.' },
  { href: '/property-search', label: 'Search the MLS', desc: 'Every active listing in the Triangle, in one place.' },
  { href: '/about/team', label: 'Meet the Team', desc: 'Four decades of local expertise, one trusted group.' },
];

const stats = [
  { value: '40+', label: 'Years of Experience' },
  { value: '6', label: 'Counties Served' },
  { value: '1000+', label: 'Homes Sold' },
  { value: '100%', label: 'Client Dedication' },
];
---

<BaseLayout title="Julie Wright Realty Group — Triangle Area Real Estate">

  <!-- ═══════════════════════════════════ HERO ═══════════════════════════════════ -->
  <section class="hero">
    <img src="/FallTopo_v2.svg" class="topo-bg topo-bg--light" alt="" aria-hidden="true" />
    <div class="relative content-wrap">
      <div class="hero-center">
        <p class="hero-eyebrow">Four Decades in the Triangle &middot; Raleigh, North Carolina</p>
        <img src="/JWRG_Full.svg" class="hero-logo" alt="Julie Wright Realty Group" />
        <h1 class="hero-tagline">Your place in the Triangle starts here.</h1>

        <!-- Search prompt -->
        <form action="/property-search" method="get" class="mt-8 w-full max-w-xl flex flex-col sm:flex-row gap-3">
          <div class="relative flex-1">
            <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-earth-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input type="text" name="q" placeholder="City, neighborhood, or address…" class="form-input pl-12" />
          </div>
          <button type="submit" class="inline-flex items-center justify-center px-7 py-3 font-display font-medium border-2 border-red-600 bg-red-600 text-earth-50 tracking-wide rounded-sm transition-all duration-300 hover:bg-red-700 hover:border-red-700 cursor-pointer shrink-0">
            Search Homes
          </button>
        </form>
        <div class="flex flex-wrap justify-center gap-x-6 gap-y-2 mt-5 text-sm">
          <a href="/property-search" class="text-earth-600 hover:text-red-600 transition-colors">Advanced Search</a>
          <a href="/property-organizer" class="text-earth-600 hover:text-red-600 transition-colors">Saved Listings</a>
          <a href="/sellers/home-value" class="text-earth-600 hover:text-red-600 transition-colors">What's My Home Worth?</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════ FEATURED LISTINGS ═══════════════════════════════════ -->
  <section class="featured-section">
    <div class="content-wrap">
      <div class="featured-header">
        <div>
          <p class="section-label">Featured</p>
          <h2 class="featured-heading">Current Listings</h2>
        </div>
        <BtnArrow href="/listings" variant="primary">View All</BtnArrow>
      </div>
      {apiError ? (
        <p class="text-earth-600 text-center py-8">Listings are temporarily unavailable — please try again shortly.</p>
      ) : featuredListings.length === 0 ? (
        <p class="text-earth-600 text-center py-8">New listings are on the way. Check back soon.</p>
      ) : (
        <div class="featured-grid">
          {featuredListings.slice(0, 6).map((listing, i) => (
            <ListingCard listing={listing} index={i} />
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- ═══════════════════════════════════ ABOUT + HOW WE HELP ═══════════════════════════════════ -->
  <section class="home-about-services">
    <div class="content-wrap">
      <div class="home-about-services-grid">
        <!-- About -->
        <div class="home-about-block">
          <h2 class="home-about-heading">
            Your resource for real estate<br />
            in the <span class="home-about-accent">Triangle</span>
          </h2>
          <p class="home-about-body">
            Julie Wright Realty Group is a full-service residential brokerage serving Wake, Granville,
            Franklin, Johnston, Harnett, and Durham counties. For four decades we've paired easy-to-use
            search tools with deep local knowledge to help families buy and sell with confidence.
          </p>
          <a href="/about" class="home-about-link">
            Our Story
            <svg class="home-link-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>

        <!-- How we help -->
        <div class="home-services-block">
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {helpLinks.map((item) => (
              <a href={item.href} class="group block bg-white rounded-sm p-5 ring-1 ring-inset ring-earth-100 hover:ring-2 hover:ring-red-600 transition-all duration-300">
                <h3 class="font-display text-base text-earth-900 group-hover:text-red-600 transition-colors">{item.label}</h3>
                <p class="text-earth-600 text-sm mt-2 leading-snug">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════ STATS ═══════════════════════════════════ -->
  <section class="cta-bold">
    <div class="content-wrap">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        {stats.map((stat) => (
          <div>
            <div class="font-display font-bold text-3xl md:text-4xl text-gold-300">{stat.value}</div>
            <div class="text-earth-400 text-sm mt-1 tracking-wide">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════ SELLER CTA ═══════════════════════════════════ -->
  <section class="cta-feature">
    <div class="cta-wrap">
      <h2 class="cta-bold-heading">Thinking about selling?</h2>
      <p class="cta-bold-body">
        Get a free, no-obligation valuation and a market strategy tailored to your property.
      </p>
      <div class="cta-btn-row">
        <BtnArrow href="/sellers/home-value" variant="inverted">Get Your Home's Value</BtnArrow>
        <BtnArrow href="/contact" variant="inverted">Talk to an Agent</BtnArrow>
      </div>
    </div>
  </section>

</BaseLayout>
