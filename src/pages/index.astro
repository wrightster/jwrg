---
import BaseLayout from '../layouts/BaseLayout.astro';

const services = [
  {
    title: 'Featured Listings',
    description: 'Browse our curated selection of exceptional properties across the Triangle Area.',
    image: 'https://reappdata.global.ssl.fastly.net/site_data/baileywrightrealty/design_assets/f165screen-shot-2020-11-12-at-6.37.39-pm.png',
    href: '/listings',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>`,
  },
  {
    title: 'Neighborhoods',
    description: 'Discover the perfect community that matches your lifestyle and needs.',
    image: 'https://reappdata.global.ssl.fastly.net/site_data/baileywrightrealty/design_assets/c8d7screen-shot-2020-11-12-at-7.01.00-pm.png',
    href: '/neighborhoods',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
  },
  {
    title: 'Communities',
    description: 'Explore Triangle Area communities with detailed area information and insights.',
    image: 'https://reappdata.global.ssl.fastly.net/site_data/baileywrightrealty/design_assets/3151images.jpg',
    href: '/communities',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>`,
  },
  {
    title: 'Home Staging',
    description: 'Expert tips to present your property at its absolute best for buyers.',
    image: 'https://reappdata.global.ssl.fastly.net/site_data/baileywrightrealty/design_assets/1375r1.jpg',
    href: '/staging',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>`,
  },
  {
    title: 'List Your Home',
    description: 'Ready to sell? Let our experienced team guide you through every step.',
    image: 'https://reappdata.global.ssl.fastly.net/site_data/baileywrightrealty/design_assets/a595screen-shot-2020-11-12-at-6.47.56-pm.png',
    href: '/list-your-home',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>`,
  },
  {
    title: 'Meet the Team',
    description: 'Get to know the experienced professionals behind Julie Wright Realty Group.',
    image: 'https://reappdata.global.ssl.fastly.net/site_data/baileywrightrealty/design_assets/4a88unnamed-2-resized-smaller.jpg',
    href: '/about',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>`,
  },
];

const stats = [
  { value: '40+', label: 'Years of Experience' },
  { value: '6', label: 'Counties Served' },
  { value: '1000+', label: 'Homes Sold' },
  { value: '100%', label: 'Client Dedication' },
];
---

<BaseLayout>
  <!-- Hero Section -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <!-- Background image -->
    <div class="absolute inset-0">
      <img
        src="https://reappdata.global.ssl.fastly.net/site_data/baileywrightrealty/design_assets/41c6kitchen-ideas-hbx110119wholehome-015-1572549271.jpg"
        alt=""
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-navy-950/70 via-navy-900/50 to-navy-950/80"></div>
    </div>

    <!-- Decorative elements -->
    <div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none">
      <div class="absolute top-20 right-10 w-72 h-72 bg-gold-500/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-20 left-10 w-96 h-96 bg-gold-400/5 rounded-full blur-3xl"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 max-w-5xl mx-auto px-6 text-center pt-32 pb-20">
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 backdrop-blur-sm rounded-full text-gold-300 text-sm font-medium tracking-wide mb-8 border border-white/10">
        <span class="w-1.5 h-1.5 bg-gold-400 rounded-full"></span>
        Four Decades of Triangle Area Expertise
      </div>

      <h1 class="font-serif text-5xl md:text-6xl lg:text-7xl text-white font-medium leading-tight mb-6">
        Find Your
        <span class="italic text-gold-400">Dream Home</span>
        <br />in the Triangle
      </h1>

      <p class="text-lg md:text-xl text-white/70 max-w-2xl mx-auto mb-10 leading-relaxed">
        Your comprehensive real estate resource for Wake, Granville, Franklin, Johnston, Harnett, and Durham Counties.
      </p>

      <!-- Search bar -->
      <div class="max-w-2xl mx-auto">
        <div class="bg-white/10 backdrop-blur-md rounded-2xl p-2 border border-white/15">
          <div class="flex flex-col sm:flex-row gap-2">
            <div class="flex-1 relative">
              <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
              <input
                type="text"
                placeholder="Search by city, neighborhood, or address..."
                class="w-full pl-12 pr-4 py-4 bg-white/10 rounded-xl text-white placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-gold-500/50 transition-all"
              />
            </div>
            <button class="px-8 py-4 bg-gold-500 hover:bg-gold-600 text-white font-semibold rounded-xl transition-all duration-300 hover:shadow-lg hover:shadow-gold-500/25 shrink-0">
              Search Properties
            </button>
          </div>
        </div>

        <div class="flex justify-center gap-6 mt-6">
          <a href="/listings" class="text-white/60 hover:text-gold-400 text-sm flex items-center gap-1.5 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
            Advanced Search
          </a>
          <a href="/favorites" class="text-white/60 hover:text-gold-400 text-sm flex items-center gap-1.5 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>
            Saved Listings
          </a>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10">
      <div class="w-6 h-10 rounded-full border-2 border-white/30 flex justify-center pt-2">
        <div class="w-1 h-2.5 bg-white/50 rounded-full animate-bounce"></div>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="relative z-10 -mt-12">
    <div class="max-w-5xl mx-auto px-6">
      <div class="bg-white rounded-2xl shadow-xl shadow-navy-900/5 p-8 grid grid-cols-2 md:grid-cols-4 gap-8">
        {stats.map(stat => (
          <div class="text-center">
            <div class="text-3xl md:text-4xl font-serif font-bold text-gold-600">{stat.value}</div>
            <div class="text-navy-500 text-sm mt-1 tracking-wide">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services / Featured Resources -->
  <section class="py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-6">
      <!-- Section header -->
      <div class="max-w-2xl mx-auto text-center mb-16">
        <div class="text-gold-600 font-medium text-sm tracking-widest uppercase mb-3">What We Offer</div>
        <h2 class="font-serif text-3xl md:text-4xl text-navy-900 font-medium mb-4">
          Your Full-Service Real Estate Partner
        </h2>
        <p class="text-navy-500 leading-relaxed">
          From finding your dream home to selling your current property, we provide comprehensive resources and expert guidance every step of the way.
        </p>
      </div>

      <!-- Service cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((service) => (
          <a
            href={service.href}
            class="group relative bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl hover:shadow-navy-900/8 transition-all duration-500 hover:-translate-y-1 border border-warm-200/50"
          >
            <div class="aspect-[4/3] overflow-hidden">
              <img
                src={service.image}
                alt={service.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-navy-950/60 via-transparent to-transparent"></div>
            </div>
            <div class="relative p-6">
              <div class="flex items-center gap-3 mb-2">
                <div class="w-10 h-10 rounded-lg bg-gold-50 text-gold-600 flex items-center justify-center group-hover:bg-gold-500 group-hover:text-white transition-colors duration-300">
                  <Fragment set:html={service.icon} />
                </div>
                <h3 class="font-serif text-lg font-semibold text-navy-900 group-hover:text-gold-700 transition-colors">
                  {service.title}
                </h3>
              </div>
              <p class="text-navy-500 text-sm leading-relaxed">
                {service.description}
              </p>
              <div class="mt-4 flex items-center text-gold-600 text-sm font-medium opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                Learn More
                <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- About / Story Section -->
  <section class="py-24 lg:py-32 bg-navy-900 relative overflow-hidden">
    <!-- Decorative -->
    <div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-to-l from-gold-500/5 to-transparent"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-gold-500/5 rounded-full blur-3xl"></div>

    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <!-- Image -->
        <div class="relative">
          <div class="aspect-[4/5] rounded-2xl overflow-hidden">
            <img
              src="https://reappdata.global.ssl.fastly.net/site_data/baileywrightrealty/design_assets/4a88unnamed-2-resized-smaller.jpg"
              alt="Julie Wright Realty Group Team"
              class="w-full h-full object-cover"
            />
          </div>
          <!-- Floating accent -->
          <div class="absolute -bottom-6 -right-6 w-32 h-32 bg-gold-500/20 rounded-2xl -z-10"></div>
          <div class="absolute -top-6 -left-6 w-24 h-24 border-2 border-gold-500/30 rounded-2xl -z-10"></div>
        </div>

        <!-- Content -->
        <div>
          <div class="text-gold-400 font-medium text-sm tracking-widest uppercase mb-3">About Us</div>
          <h2 class="font-serif text-3xl md:text-4xl text-white font-medium mb-6 leading-snug">
            Your Resource for Real Estate in the Triangle Area
          </h2>
          <div class="space-y-4 text-navy-300 leading-relaxed">
            <p>
              Thank you for visiting Julie Wright Realty Group. We are your comprehensive real estate resource for the Triangle Area, including Wake, Granville, Franklin, Johnston, Harnett, and Durham Counties.
            </p>
            <p>
              With over four decades of experience, we provide the tools and knowledge you need to confidently navigate your real estate journey. From easy-to-use property search tools to in-depth local area information, we're here to help you build a future in the Triangle.
            </p>
            <p>
              We specialize in providing our clients with comprehensive information surrounding their real estate purchase&mdash;from finding the right lifestyle, choosing the right property, and connecting you with the right people to support your transaction.
            </p>
          </div>
          <div class="flex flex-wrap gap-4 mt-8">
            <a
              href="/about"
              class="px-8 py-3.5 bg-gold-500 hover:bg-gold-600 text-white font-semibold rounded-lg transition-all duration-300 hover:shadow-lg hover:shadow-gold-500/25"
            >
              Our Story
            </a>
            <a
              href="/contact"
              class="px-8 py-3.5 border border-white/20 text-white hover:bg-white/10 font-semibold rounded-lg transition-all duration-300"
            >
              Get in Touch
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Home Valuation CTA -->
  <section class="py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-6">
      <div class="relative bg-gradient-to-br from-warm-100 to-warm-50 rounded-3xl overflow-hidden p-10 md:p-16 border border-warm-200">
        <!-- Decorative -->
        <div class="absolute top-0 right-0 w-64 h-64 bg-gold-500/10 rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 left-1/4 w-48 h-48 bg-gold-400/5 rounded-full blur-2xl"></div>

        <div class="relative z-10 grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <div class="text-gold-600 font-medium text-sm tracking-widest uppercase mb-3">For Sellers</div>
            <h2 class="font-serif text-3xl md:text-4xl text-navy-900 font-medium mb-4 leading-snug">
              Considering Listing Your Property?
            </h2>
            <p class="text-navy-500 leading-relaxed mb-4">
              In any real estate market, sellers want to know how much their property is worth. We understand how to answer that question using up-to-date information about the market and its direction.
            </p>
            <p class="text-navy-500 leading-relaxed">
              Combined with a unique market strategy tailored to your specific property, we'll manage the selling process with you from start to finish.
            </p>
          </div>

          <div class="bg-white rounded-2xl p-8 shadow-lg shadow-navy-900/5">
            <h3 class="font-serif text-xl text-navy-900 font-semibold mb-2">Discover Your Home's Value</h3>
            <p class="text-navy-400 text-sm mb-6">Get a free, no-obligation property valuation from our team.</p>
            <form class="space-y-4">
              <input
                type="text"
                placeholder="Property Address"
                class="w-full px-4 py-3 rounded-lg border border-warm-200 focus:outline-none focus:ring-2 focus:ring-gold-500/30 focus:border-gold-500 transition-all text-navy-900 placeholder-navy-300"
              />
              <input
                type="text"
                placeholder="City, State, ZIP"
                class="w-full px-4 py-3 rounded-lg border border-warm-200 focus:outline-none focus:ring-2 focus:ring-gold-500/30 focus:border-gold-500 transition-all text-navy-900 placeholder-navy-300"
              />
              <button
                type="submit"
                class="w-full py-3.5 bg-gold-500 hover:bg-gold-600 text-white font-semibold rounded-lg transition-all duration-300 hover:shadow-lg hover:shadow-gold-500/25"
              >
                Get Your Free Valuation
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Neighborhoods Section -->
  <section class="py-24 lg:py-32 bg-warm-100/50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="max-w-2xl mx-auto text-center mb-16">
        <div class="text-gold-600 font-medium text-sm tracking-widest uppercase mb-3">Explore</div>
        <h2 class="font-serif text-3xl md:text-4xl text-navy-900 font-medium mb-4">
          Triangle Area Neighborhoods
        </h2>
        <p class="text-navy-500 leading-relaxed">
          Discover the lifestyle, amenities, and character of communities across Wake, Granville, Franklin, Johnston, Harnett, and Durham Counties.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {['Wake County', 'Durham County', 'Johnston County'].map((county) => (
          <a href="/neighborhoods" class="group relative aspect-[3/2] rounded-2xl overflow-hidden">
            <img
              src="https://reappdata.global.ssl.fastly.net/site_data/baileywrightrealty/design_assets/c8d7screen-shot-2020-11-12-at-7.01.00-pm.png"
              alt={county}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-navy-950/80 via-navy-900/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-6">
              <h3 class="font-serif text-xl text-white font-medium">{county}</h3>
              <div class="mt-2 flex items-center text-gold-400 text-sm font-medium opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                Explore
                <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="text-center mt-10">
        <a href="/neighborhoods" class="inline-flex items-center gap-2 px-8 py-3.5 border-2 border-navy-900 text-navy-900 hover:bg-navy-900 hover:text-white font-semibold rounded-lg transition-all duration-300">
          View All Neighborhoods
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-16">
        <!-- Left -->
        <div>
          <div class="text-gold-600 font-medium text-sm tracking-widest uppercase mb-3">Contact</div>
          <h2 class="font-serif text-3xl md:text-4xl text-navy-900 font-medium mb-6 leading-snug">
            Questions? We'd Love to Hear from You
          </h2>
          <p class="text-navy-500 leading-relaxed mb-8">
            Whether you're buying, selling, or just exploring your options, our team is here to help. Reach out and let us put our decades of experience to work for you.
          </p>

          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-gold-50 text-gold-600 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              </div>
              <div>
                <div class="font-semibold text-navy-900 mb-1">Phone</div>
                <a href="tel:919-847-7140" class="text-navy-500 hover:text-gold-600 transition-colors">(919) 847-7140</a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-gold-50 text-gold-600 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
              <div>
                <div class="font-semibold text-navy-900 mb-1">Email</div>
                <a href="mailto:info@juliewrightrealtygroup.com" class="text-navy-500 hover:text-gold-600 transition-colors">info@juliewrightrealtygroup.com</a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-gold-50 text-gold-600 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
              <div>
                <div class="font-semibold text-navy-900 mb-1">Office</div>
                <p class="text-navy-500">10931 Strickland Rd, Ste 111<br />Raleigh, NC 27615</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Form -->
        <div class="bg-white rounded-2xl p-8 md:p-10 shadow-lg shadow-navy-900/5 border border-warm-200/50">
          <h3 class="font-serif text-xl text-navy-900 font-semibold mb-6">Send Us a Message</h3>
          <form class="space-y-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="name" class="block text-sm font-medium text-navy-700 mb-1.5">Name *</label>
                <input
                  type="text"
                  id="name"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-warm-200 focus:outline-none focus:ring-2 focus:ring-gold-500/30 focus:border-gold-500 transition-all text-navy-900 placeholder-navy-300"
                  placeholder="Your full name"
                />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-navy-700 mb-1.5">Phone *</label>
                <input
                  type="tel"
                  id="phone"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-warm-200 focus:outline-none focus:ring-2 focus:ring-gold-500/30 focus:border-gold-500 transition-all text-navy-900 placeholder-navy-300"
                  placeholder="(XXX) XXX-XXXX"
                />
              </div>
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-navy-700 mb-1.5">Email *</label>
              <input
                type="email"
                id="email"
                required
                class="w-full px-4 py-3 rounded-lg border border-warm-200 focus:outline-none focus:ring-2 focus:ring-gold-500/30 focus:border-gold-500 transition-all text-navy-900 placeholder-navy-300"
                placeholder="your@email.com"
              />
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-navy-700 mb-1.5">Message *</label>
              <textarea
                id="message"
                rows="4"
                required
                class="w-full px-4 py-3 rounded-lg border border-warm-200 focus:outline-none focus:ring-2 focus:ring-gold-500/30 focus:border-gold-500 transition-all text-navy-900 placeholder-navy-300 resize-none"
                placeholder="How can we help you?"
              ></textarea>
            </div>
            <p class="text-navy-400 text-xs leading-relaxed">
              By submitting this form, you are giving Julie Wright Realty Group permission to contact you via email, phone, or text.
            </p>
            <button
              type="submit"
              class="w-full py-3.5 bg-gold-500 hover:bg-gold-600 text-white font-semibold rounded-lg transition-all duration-300 hover:shadow-lg hover:shadow-gold-500/25"
            >
              Send Message
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
