---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found | Julie Wright Realty Group">
  <section class="min-h-[70vh] flex items-center justify-center pt-24 pb-16">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <div class="text-7xl md:text-9xl font-serif font-bold text-gold-500/40">404</div>
      <h1 class="font-serif text-3xl md:text-4xl text-navy-900 font-medium mt-4 mb-4">
        Page Not Found
      </h1>
      <p class="text-navy-500 text-lg leading-relaxed mb-8">
        The page you're looking for doesn't exist or has been moved. Use the links below to get back on track.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/" class="px-8 py-3.5 bg-gold-500 hover:bg-gold-600 text-white font-semibold rounded-lg transition-all">
          Back to Home
        </a>
        <a href="/listings" class="px-8 py-3.5 border-2 border-navy-900 text-navy-900 hover:bg-navy-900 hover:text-white font-semibold rounded-lg transition-all">
          Browse Listings
        </a>
        <a href="/contact" class="px-8 py-3.5 border-2 border-warm-300 text-navy-700 hover:bg-warm-100 font-semibold rounded-lg transition-all">
          Contact Us
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
