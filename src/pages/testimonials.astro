---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageBanner from '../components/PageBanner.astro';
import EmbedForm from '../components/EmbedForm.astro';
import MiniContactForm from '../components/MiniContactForm.astro';
import { site } from '../data/site';

export const prerender = true;

// Seed testimonials live in src/data/testimonials.ts when available.
// Until then, render the submission form so clients can leave a review.

const formToken = site.formTokens.testimonial;
---

<BaseLayout title="Testimonials | Julie Wright Realty Group">
  <PageBanner
    label="Client Stories"
    title="Testimonials"
    description="The best measure of our work is what our clients say after the keys are handed over."
  />

  <section class="py-16">
    <div class="max-w-3xl mx-auto px-6">
      <div class="bg-white rounded-sm p-8 md:p-10">
        <h2 class="contact-form-heading">Share Your Experience</h2>
        <p class="text-earth-600 mb-6">If we've helped you buy, sell, or relocate, we'd love to hear from you. Your testimonial may be featured on our website.</p>
        {formToken ? (
          <EmbedForm id="jwrg-testimonial-form" token={formToken} />
        ) : (
          <p class="text-earth-600 leading-relaxed">
            Our online testimonial form is being configured. In the meantime, please share your story
            by <a href={`mailto:${site.email}`} class="text-red-600 hover:underline">email</a>.
          </p>
        )}
      </div>
    </div>
  </section>

  <MiniContactForm />
</BaseLayout>
