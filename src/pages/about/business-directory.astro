---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageBanner from '../../components/PageBanner.astro';
import MiniContactForm from '../../components/MiniContactForm.astro';

export const prerender = true;

const categories = [
  'Mortgage & Lending',
  'Home Inspection',
  'Real Estate Attorney',
  'Title & Escrow',
  'Surveyor',
  'General Contractor',
  'Roofing',
  'HVAC',
  'Plumbing & Electrical',
  'Landscaping',
  'Cleaning & Staging',
  'Moving Companies',
  'Insurance',
  'Pest Control',
];
---

<BaseLayout title="Business Directory | Julie Wright Realty Group">
  <PageBanner
    label="Local Resources"
    title="Business Directory"
    description="A curated directory of local professionals we have worked with and trust. Use it to find the right vendor for any step of buying, selling, or owning a home."
  />

  <section class="py-16">
    <div class="max-w-5xl mx-auto px-6">
      <div class="bg-white rounded-2xl p-8 border border-warm-200/50 shadow-sm mb-12">
        <h2 class="font-serif text-2xl text-navy-900 font-medium mb-4">Search the Directory</h2>
        <p class="text-navy-500 mb-6">
          Browse by category below, or contact our office for a personal recommendation tailored to your specific need or location.
        </p>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
          {categories.map((c) => (
            <button class="px-4 py-3 bg-warm-100/60 hover:bg-gold-50 hover:text-gold-700 text-navy-700 text-sm rounded-lg border border-warm-200/60 transition-all text-left">
              {c}
            </button>
          ))}
        </div>
      </div>

      <div class="bg-warm-100/60 border border-warm-200 rounded-2xl p-8 text-center">
        <h3 class="font-serif text-xl text-navy-900 font-semibold mb-2">Need a personal recommendation?</h3>
        <p class="text-navy-500 mb-6 max-w-2xl mx-auto">
          Every transaction is different. Tell us what you need and we'll connect you with the right local professional from our network.
        </p>
        <a href="/contact" class="inline-block px-8 py-3.5 bg-gold-500 hover:bg-gold-600 text-white font-semibold rounded-lg transition-all">
          Ask for a Recommendation
        </a>
      </div>
    </div>
  </section>

  <MiniContactForm />
</BaseLayout>
