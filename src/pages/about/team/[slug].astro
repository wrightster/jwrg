---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import MiniContactForm from '../../../components/MiniContactForm.astro';
import { fetchTeam, fetchTeamMember, photoSrc, type ApiTeamMember } from '../../../lib/api';

export async function getStaticPaths() {
  const team = await fetchTeam();
  return team.map((m) => ({ params: { slug: m.slug } }));
}

const { slug } = Astro.params;
const member: ApiTeamMember | null = slug ? await fetchTeamMember(slug) : null;

if (!member) {
  return Astro.redirect('/404');
}

const photo = photoSrc(member.primary_photo, 1200);
const firstName = member.name.split(' ')[0];
const phoneDigits = member.public_phone?.replace(/[^0-9]/g, '') ?? '';
const longBio = member.bio ?? member.short_bio ?? '';
---

<BaseLayout
  title={`${member.name}${member.title ? ' — ' + member.title : ''} | Julie Wright Realty Group`}
  description={member.short_bio ?? member.bio ?? `${member.name} — Julie Wright Realty Group`}
>
  <section class="pt-32 pb-12">
    <div class="max-w-5xl mx-auto px-6">
      <a href="/about/team" class="text-sm text-gold-600 hover:text-gold-700 inline-flex items-center gap-1 mb-8">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Back to team
      </a>

      <div class="grid md:grid-cols-3 gap-10 items-start">
        <div class="md:col-span-1">
          <div class="aspect-[4/5] overflow-hidden rounded-sm bg-warm-100">
            {photo ? (
              <img src={photo} alt={member.primary_photo?.alt ?? member.name} class="w-full h-full object-cover" />
            ) : (
              <div class="w-full h-full flex items-center justify-center text-navy-300">
                <svg class="w-32 h-32" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
              </div>
            )}
          </div>
        </div>

        <div class="md:col-span-2">
          {member.title && (
            <div class="text-gold-600 text-sm font-medium tracking-widest uppercase mb-2">{member.title}</div>
          )}
          <h1 class="font-serif text-3xl md:text-5xl text-navy-900 font-medium leading-tight mb-6">
            {member.name}
          </h1>

          {longBio && (
            <p class="text-navy-700 leading-relaxed text-lg mb-8 whitespace-pre-line">{longBio}</p>
          )}

          {member.specialties.length > 0 && (
            <div class="mb-8">
              <div class="text-navy-500 text-xs tracking-widest uppercase mb-3">Specialties</div>
              <div class="flex flex-wrap gap-2">
                {member.specialties.map((s) => (
                  <span class="px-3 py-1 bg-warm-100 text-navy-700 text-sm rounded-full border border-warm-200">{s}</span>
                ))}
              </div>
            </div>
          )}

          {(member.license_number || member.years_experience !== null) && (
            <div class="mb-8 flex flex-wrap gap-x-8 gap-y-2 text-sm text-navy-600">
              {member.license_number && (
                <span>
                  <span class="text-navy-400">{member.license_state ?? 'License'}</span>{' '}
                  <span>#{member.license_number}</span>
                </span>
              )}
              {member.years_experience !== null && (
                <span>
                  <span class="text-navy-400">Experience</span>{' '}
                  <span>{member.years_experience} years</span>
                </span>
              )}
            </div>
          )}

          {(phoneDigits || member.public_email) && (
            <div class="space-y-3 pt-6 border-t border-warm-200">
              {member.public_phone && (
                <a href={`tel:${phoneDigits}`} class="flex items-center gap-3 text-navy-700 hover:text-gold-600 transition-colors">
                  <svg class="w-5 h-5 text-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                  {member.public_phone}
                </a>
              )}
              {member.public_email && (
                <a href={`mailto:${member.public_email}`} class="flex items-center gap-3 text-navy-700 hover:text-gold-600 transition-colors">
                  <svg class="w-5 h-5 text-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                  {member.public_email}
                </a>
              )}
            </div>
          )}

          {Object.keys(member.social_links).length > 0 && (
            <div class="mt-6 flex flex-wrap gap-4 text-sm">
              {Object.entries(member.social_links).map(([network, url]) => (
                <a href={url} target="_blank" rel="noopener" class="text-gold-600 hover:text-gold-700 capitalize">
                  {network}
                </a>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <MiniContactForm
    heading={`Connect with ${firstName}`}
    description="Send a message — we'll forward it directly to make sure you get a quick response."
  />
</BaseLayout>
