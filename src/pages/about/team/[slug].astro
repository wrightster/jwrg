---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import MiniContactForm from '../../../components/MiniContactForm.astro';
import { team, type TeamMember } from '../../../data/team';

export const prerender = true;

export function getStaticPaths() {
  return team.map((m) => ({ params: { slug: m.slug }, props: { member: m } }));
}

interface Props {
  member: TeamMember;
}

const { member } = Astro.props;
const photo = member.photo || member.remotePhoto;
---

<BaseLayout title={`${member.name} — ${member.role} | Julie Wright Realty Group`} description={member.bio}>
  <section class="pt-32 pb-12">
    <div class="max-w-5xl mx-auto px-6">
      <a href="/about/team" class="text-sm text-gold-600 hover:text-gold-700 inline-flex items-center gap-1 mb-8">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Back to team
      </a>

      <div class="grid md:grid-cols-3 gap-10 items-start">
        <div class="md:col-span-1">
          <div class="aspect-[4/5] overflow-hidden rounded-2xl bg-warm-100">
            {photo ? (
              <img src={photo} alt={member.name} class="w-full h-full object-cover" />
            ) : (
              <div class="w-full h-full flex items-center justify-center text-navy-300">
                <svg class="w-32 h-32" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
              </div>
            )}
          </div>
        </div>

        <div class="md:col-span-2">
          <div class="text-gold-600 text-sm font-medium tracking-widest uppercase mb-2">{member.role}</div>
          <h1 class="font-serif text-3xl md:text-5xl text-navy-900 font-medium leading-tight mb-6">
            {member.name}
          </h1>

          <p class="text-navy-700 leading-relaxed text-lg mb-8">{member.bio}</p>

          {member.specialties.length > 0 && (
            <div class="mb-8">
              <div class="text-navy-500 text-xs tracking-widest uppercase mb-3">Specialties</div>
              <div class="flex flex-wrap gap-2">
                {member.specialties.map((s) => (
                  <span class="px-3 py-1 bg-warm-100 text-navy-700 text-sm rounded-full border border-warm-200">{s}</span>
                ))}
              </div>
            </div>
          )}

          <div class="space-y-3 pt-6 border-t border-warm-200">
            <a href={`tel:${member.phone.replace(/[^0-9]/g, '')}`} class="flex items-center gap-3 text-navy-700 hover:text-gold-600 transition-colors">
              <svg class="w-5 h-5 text-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              {member.phone}
            </a>
            {member.email && (
              <a href={`mailto:${member.email}`} class="flex items-center gap-3 text-navy-700 hover:text-gold-600 transition-colors">
                <svg class="w-5 h-5 text-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                {member.email}
              </a>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <MiniContactForm
    heading={`Connect with ${member.name.split(' ')[0]}`}
    description="Send a message — we'll forward it directly to make sure you get a quick response."
  />
</BaseLayout>
