---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageBanner from '../../components/PageBanner.astro';
import Form from '../../components/Form.astro';
import type { Field } from '../../lib/formFields';
import MiniContactForm from '../../components/MiniContactForm.astro';

export const prerender = true;

const fields: Field[] = [
  { type: 'text', name: 'first_name', label: 'First Name', required: true, cols: 1 },
  { type: 'text', name: 'last_name', label: 'Last Name', required: true, cols: 1 },
  { type: 'email', name: 'email', label: 'Email', required: true, cols: 1 },
  { type: 'tel', name: 'phone', label: 'Phone', cols: 1 },
  { type: 'text', name: 'address', label: 'Current Address', cols: 2 },
  { type: 'text', name: 'city', label: 'City', cols: 1 },
  { type: 'text', name: 'state', label: 'State', cols: 1 },
  { type: 'text', name: 'zip', label: 'Zip', cols: 1 },
  {
    type: 'select',
    name: 'sell_first',
    label: 'Do you need to sell before relocating?',
    options: ['Yes', 'No', 'Not sure'],
    cols: 1,
  },
  {
    type: 'select',
    name: 'contact_pref',
    label: 'Best way to contact you',
    options: ['Email', 'Phone', 'Text'],
    cols: 1,
  },
  {
    type: 'select',
    name: 'visit_timing',
    label: 'When are you planning to visit the Triangle?',
    options: ['Within 30 days', '1–3 months', '3–6 months', '6–12 months', 'No specific timeline'],
    cols: 1,
  },
  {
    type: 'select',
    name: 'home_type',
    label: 'Preferred Home Type',
    options: ['Single-Family', 'Townhome', 'Condo', 'Land', 'Farm / Estate', 'New Construction'],
    cols: 1,
  },
  { type: 'textarea', name: 'important_features', label: 'Important features or must-haves', cols: 2 },
  {
    type: 'select',
    name: 'price_range',
    label: 'Price Range',
    options: [
      'Under $300,000',
      '$300,000 — $500,000',
      '$500,000 — $750,000',
      '$750,000 — $1,000,000',
      'Over $1,000,000',
    ],
    cols: 1,
  },
  { type: 'select', name: 'beds', label: 'Minimum Bedrooms', options: ['1', '2', '3', '4', '5+'], cols: 1 },
  { type: 'select', name: 'baths', label: 'Minimum Bathrooms', options: ['1', '2', '3', '4+'], cols: 1 },
  { type: 'text', name: 'target_area', label: 'Target Area or Cities', cols: 2 },
  {
    type: 'select',
    name: 'neighborhood_features',
    label: 'Preferred Neighborhood Features',
    options: ['Walkable', 'Schools / Family-Friendly', 'Quiet / Rural', 'Acreage', '55+ / Active Adult', 'Downtown / Urban'],
    cols: 2,
  },
  { type: 'textarea', name: 'additional_comments', label: 'Anything else we should know?', cols: 2 },
];
---

<BaseLayout title="Free Relocation Package | Julie Wright Realty Group">
  <PageBanner
    label="Relocating to the Triangle"
    title="Complimentary Relocation Package"
    description="Tell us about your move and we'll send a customized Triangle area relocation package — at no cost to you."
  />

  <section class="py-16">
    <div class="max-w-3xl mx-auto px-6">
      <Form
        formKey="relocation"
        title="Request Your Relocation Package"
        description="Required fields are marked with an asterisk."
        submitLabel="Request Package"
        fields={fields}
      />
    </div>
  </section>

  <MiniContactForm />
</BaseLayout>
