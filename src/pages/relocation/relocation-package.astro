---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageBanner from '../../components/PageBanner.astro';
import EmbedForm from '../../components/EmbedForm.astro';
import MiniContactForm from '../../components/MiniContactForm.astro';
import { site } from '../../data/site';

export const prerender = true;

// The relocation form's fields are now defined on the office side (see the
// Filament Embed Forms admin); the office widget renders them based on the
// token. Paste the token into site.formTokens.relocation when the form is
// created.
const formToken = site.formTokens.relocation;
---

<BaseLayout title="Free Relocation Package | Julie Wright Realty Group">
  <PageBanner
    label="Relocating to the Triangle"
    title="Complimentary Relocation Package"
    description="Tell us about your move and we'll send a customized Triangle area relocation package — at no cost to you."
  />

  <section class="py-16">
    <div class="max-w-3xl mx-auto px-6">
      <div class="bg-white rounded-sm p-8 md:p-10">
        <h2 class="contact-form-heading">Request Your Relocation Package</h2>
        <p class="text-earth-600 mb-6">Required fields are marked with an asterisk.</p>
        {formToken ? (
          <EmbedForm id="jwrg-relocation-form" token={formToken} />
        ) : (
          <p class="text-earth-600 leading-relaxed">
            Our online relocation request form is being configured. In the meantime, please reach us
            by <a href={`tel:${site.phoneRaw}`} class="text-red-600 hover:underline">phone</a>
            or <a href={`mailto:${site.email}`} class="text-red-600 hover:underline">email</a>
            and we'll send your customized Triangle relocation package.
          </p>
        )}
      </div>
    </div>
  </section>

  <MiniContactForm />
</BaseLayout>
