---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageBanner from '../components/PageBanner.astro';
import MiniContactForm from '../components/MiniContactForm.astro';

export const prerender = true;
---

<BaseLayout title="MLS Property Search | Julie Wright Realty Group">
  <PageBanner
    label="MLS Search"
    title="Search Triangle Area Properties"
    description="Search the full Doorify MLS feed for homes, land, and commercial properties across the Triangle and surrounding counties."
  />

  <section class="py-16">
    <div class="max-w-5xl mx-auto px-6">
      <div class="bg-white rounded-sm shadow-lg shadow-navy-900/5 border border-warm-200/50 overflow-hidden">
        <iframe
          src="https://search.juliewrightrealtygroup.com"
          class="w-full"
          style="height: 80vh; min-height: 600px; border: 0;"
          title="MLS Property Search"
          loading="lazy"
        ></iframe>
      </div>
      <p class="text-navy-500 text-sm text-center mt-6">
        Search results powered by Doorify MLS of North Carolina.
        <a href="https://search.juliewrightrealtygroup.com" target="_blank" rel="noopener" class="text-gold-700 hover:underline">
          Open in a new window
        </a>.
      </p>
    </div>
  </section>

  <MiniContactForm />
</BaseLayout>
