---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageBanner from '../../components/PageBanner.astro';
import EmbedForm from '../../components/EmbedForm.astro';
import MiniContactForm from '../../components/MiniContactForm.astro';
import { site } from '../../data/site';

export const prerender = true;

const formToken = site.formTokens.soldReport;
---

<BaseLayout title="Neighborhood Sold Report | Julie Wright Realty Group">
  <PageBanner
    label="For Sellers"
    title="Neighborhood Sold Report"
    description="See what comparable homes in your neighborhood have recently sold for. We'll prepare a custom report based on your address and send it within one business day."
  />

  <section class="py-16">
    <div class="max-w-3xl mx-auto px-6">
      <div class="bg-white rounded-sm p-8 md:p-10">
        <h2 class="contact-form-heading">Request Your Sold Report</h2>
        {formToken ? (
          <EmbedForm id="jwrg-sold-report-form" token={formToken} />
        ) : (
          <p class="text-earth-600 leading-relaxed">
            Our online sold-report request form is being configured. In the meantime, please reach us
            by <a href={`tel:${site.phoneRaw}`} class="text-red-600 hover:underline">phone</a>
            or <a href={`mailto:${site.email}`} class="text-red-600 hover:underline">email</a>.
          </p>
        )}
      </div>
    </div>
  </section>

  <MiniContactForm />
</BaseLayout>
