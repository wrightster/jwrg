---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageBanner from '../../components/PageBanner.astro';
import EmbedForm from '../../components/EmbedForm.astro';
import MiniContactForm from '../../components/MiniContactForm.astro';
import { site } from '../../data/site';

export const prerender = true;

const formToken = site.formTokens.listYourHome;
---

<BaseLayout title="List Your Property | Julie Wright Realty Group">
  <PageBanner
    label="For Sellers"
    title="List Your Property with Julie Wright Realty"
    description="Tell us about your property and we'll schedule an in-person consultation to discuss pricing, timing, and a marketing plan tailored to your home."
  />

  <section class="py-16">
    <div class="max-w-3xl mx-auto px-6">
      <div class="bg-white rounded-sm p-8 md:p-10">
        <h2 class="contact-form-heading">Tell Us About Your Property</h2>
        <p class="text-earth-600 mb-6">We'll be in touch to schedule an in-person consultation.</p>
        {formToken ? (
          <EmbedForm id="jwrg-list-property-form" token={formToken} />
        ) : (
          <p class="text-earth-600 leading-relaxed">
            Our online listing consultation form is being configured. In the meantime, please reach us
            by <a href={`tel:${site.phoneRaw}`} class="text-red-600 hover:underline">phone</a>
            or <a href={`mailto:${site.email}`} class="text-red-600 hover:underline">email</a>.
          </p>
        )}
      </div>
    </div>
  </section>

  <MiniContactForm />
</BaseLayout>
