---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageBanner from '../../components/PageBanner.astro';
import MiniContactForm from '../../components/MiniContactForm.astro';
import { stagingSections } from '../../data/stagingTips';

export const prerender = true;
---

<BaseLayout title="Staging Tips | Julie Wright Realty Group">
  <PageBanner
    label="For Sellers"
    title="Staging Tips to Sell Your Home Faster"
    description="Practical, low-cost ways to make your property show its best. Most of these you can do yourself in a weekend."
  />

  <section class="py-16">
    <div class="max-w-3xl mx-auto px-6 space-y-12">
      {stagingSections.map((s) => (
        <div>
          <h2 class="font-serif text-2xl md:text-3xl text-navy-900 font-medium mb-4 pb-3 border-b border-warm-200">
            {s.heading}
          </h2>
          <div class="space-y-4 text-navy-700 leading-relaxed">
            {s.body.map((p) => <p>{p}</p>)}
          </div>
        </div>
      ))}

      <div class="bg-warm-100/60 border border-warm-200 rounded-2xl p-8 text-center">
        <h3 class="font-serif text-xl text-navy-900 font-semibold mb-2">Request a Complimentary Home Evaluation</h3>
        <p class="text-navy-500 mb-6">We'll walk through your property in person and identify the highest-impact improvements before you list.</p>
        <a href="/sellers/home-value" class="inline-block px-8 py-3.5 bg-gold-500 hover:bg-gold-600 text-white font-semibold rounded-lg transition-all">
          Request Evaluation
        </a>
      </div>
    </div>
  </section>

  <MiniContactForm />
</BaseLayout>
