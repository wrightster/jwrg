---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageBanner from '../../components/PageBanner.astro';
import MiniContactForm from '../../components/MiniContactForm.astro';

export const prerender = true;
---

<BaseLayout title="Mortgage Calculator | Julie Wright Realty Group">
  <PageBanner
    label="For Buyers"
    title="Mortgage Calculator"
    description="Estimate your monthly mortgage payment, including principal, interest, taxes, and insurance."
  />

  <section class="py-16">
    <div class="max-w-4xl mx-auto px-6">
      <div class="bg-white border border-warm-200/50 rounded-sm shadow-lg shadow-navy-900/5 p-8 md:p-10">
        <form id="mortgage-form" class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div>
            <label class="block text-sm font-medium text-navy-700 mb-1.5" for="loanAmount">Loan Amount ($)</label>
            <input id="loanAmount" type="number" min="0" step="1000" value="350000" class="w-full px-4 py-3 rounded-sm border border-warm-200 focus:outline-none focus:ring-2 focus:ring-gold-500/30 focus:border-gold-500 text-navy-900" />
          </div>
          <div>
            <label class="block text-sm font-medium text-navy-700 mb-1.5" for="years">Loan Term (years)</label>
            <input id="years" type="number" min="1" max="40" value="30" class="w-full px-4 py-3 rounded-sm border border-warm-200 focus:outline-none focus:ring-2 focus:ring-gold-500/30 focus:border-gold-500 text-navy-900" />
          </div>
          <div>
            <label class="block text-sm font-medium text-navy-700 mb-1.5" for="rate">Interest Rate (%)</label>
            <input id="rate" type="number" min="0" max="20" step="0.01" value="6.5" class="w-full px-4 py-3 rounded-sm border border-warm-200 focus:outline-none focus:ring-2 focus:ring-gold-500/30 focus:border-gold-500 text-navy-900" />
          </div>
          <div>
            <label class="block text-sm font-medium text-navy-700 mb-1.5" for="annualTax">Annual Property Tax ($)</label>
            <input id="annualTax" type="number" min="0" step="100" value="3600" class="w-full px-4 py-3 rounded-sm border border-warm-200 focus:outline-none focus:ring-2 focus:ring-gold-500/30 focus:border-gold-500 text-navy-900" />
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-navy-700 mb-1.5" for="annualInsurance">Annual Insurance ($)</label>
            <input id="annualInsurance" type="number" min="0" step="100" value="1500" class="w-full px-4 py-3 rounded-sm border border-warm-200 focus:outline-none focus:ring-2 focus:ring-gold-500/30 focus:border-gold-500 text-navy-900" />
          </div>
        </form>

        <div class="mt-10 p-8 bg-warm-100/60 rounded-sm border border-warm-200/60">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
            <div>
              <div class="text-navy-500 text-xs tracking-widest uppercase">P&I</div>
              <div id="out-pi" class="text-2xl font-serif font-bold text-navy-900 mt-1">—</div>
            </div>
            <div>
              <div class="text-navy-500 text-xs tracking-widest uppercase">Tax</div>
              <div id="out-tax" class="text-2xl font-serif font-bold text-navy-900 mt-1">—</div>
            </div>
            <div>
              <div class="text-navy-500 text-xs tracking-widest uppercase">Insurance</div>
              <div id="out-ins" class="text-2xl font-serif font-bold text-navy-900 mt-1">—</div>
            </div>
            <div>
              <div class="text-gold-600 text-xs tracking-widest uppercase">Total / Month</div>
              <div id="out-total" class="text-2xl font-serif font-bold text-gold-700 mt-1">—</div>
            </div>
          </div>
        </div>

        <p class="text-navy-400 text-xs leading-relaxed mt-6">
          Estimates only. Actual loan terms depend on your lender, credit, down payment, and other factors. Talk to a licensed mortgage professional for an exact quote.
        </p>
      </div>
    </div>
  </section>

  <MiniContactForm
    heading="Ready to talk to a lender?"
    description="We can connect you with trusted local mortgage professionals — no obligation."
  />
</BaseLayout>

<script>
  function fmt(n: number): string {
    if (!Number.isFinite(n)) return '—';
    return '$' + Math.round(n).toLocaleString('en-US');
  }

  function calc() {
    const loan = parseFloat((document.getElementById('loanAmount') as HTMLInputElement).value) || 0;
    const years = parseFloat((document.getElementById('years') as HTMLInputElement).value) || 0;
    const rate = parseFloat((document.getElementById('rate') as HTMLInputElement).value) || 0;
    const tax = parseFloat((document.getElementById('annualTax') as HTMLInputElement).value) || 0;
    const ins = parseFloat((document.getElementById('annualInsurance') as HTMLInputElement).value) || 0;

    const r = rate / 100 / 12;
    const n = years * 12;
    const pi = r === 0 ? loan / n : (loan * r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
    const taxMonthly = tax / 12;
    const insMonthly = ins / 12;

    document.getElementById('out-pi')!.textContent = fmt(pi);
    document.getElementById('out-tax')!.textContent = fmt(taxMonthly);
    document.getElementById('out-ins')!.textContent = fmt(insMonthly);
    document.getElementById('out-total')!.textContent = fmt(pi + taxMonthly + insMonthly);
  }

  document.getElementById('mortgage-form')?.addEventListener('input', calc);
  calc();
</script>
