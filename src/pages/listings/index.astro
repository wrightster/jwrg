---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BtnArrow from '../../components/BtnArrow.astro';
import ListingCard from '../../components/ListingCard.astro';
import ListingRow from '../../components/ListingRow.astro';
import { fetchListings, type ApiListing } from '../../lib/api';
export const prerender = true;

let apiError = false;
let listings: ApiListing[] = [];
try {
  listings = await fetchListings({ perPage: 200 });
} catch {
  apiError = true;
}

const counties = [...new Set(listings.map(l => l.county))].filter(Boolean).sort();
const cities   = [...new Set(listings.map(l => l.city))].filter(Boolean).sort();
---

<BaseLayout title="Listings — Julie Wright Realty Group" description="Browse homes for sale across Wake, Granville, Franklin, Johnston, Harnett, and Durham counties.">
  <!-- Page Header -->
  <section class="page-banner">
    <div class="content-wrap">
      <h1 class="page-banner-title">Our Listings</h1>
      <p class="page-banner-desc">
        Homes for sale across Wake, Granville, Franklin, Johnston, Harnett, and Durham counties.
      </p>
    </div>
  </section>

  <!-- Listings Grid -->
  <section class="listings-section">
    <div class="content-wrap">
      {apiError ? (
        <div class="py-16 text-center">
          <p class="text-earth-700">Our listings are temporarily unavailable — please try again shortly.</p>
          <p class="text-earth-500 text-sm mt-2">Or <a href="/contact" class="text-red-600 underline underline-offset-2">contact us</a> directly and we'll be happy to help.</p>
        </div>
      ) : (
        <>
      <!-- Filter bar -->
      <div class="filter-bar" id="filter-bar">
        <button class="filter-toggle-btn" id="filter-toggle" type="button" aria-expanded="false" aria-controls="filter-collapse">
          <svg class="filter-toggle-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
          <span class="filter-toggle-label">Filters</span>
          <span class="filter-toggle-count" id="filter-active-count" aria-live="polite"></span>
          <svg class="filter-toggle-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="filter-collapse" id="filter-collapse">
          <div class="filter-collapse-inner">
            <div class="filter-controls-row">

          <!-- County dropdown -->
          <div class="filter-select-wrap">
            <span class="filter-select-label">County</span>
            <div class="custom-select" data-filter="county">
              <button class="custom-select-trigger" type="button" aria-haspopup="listbox" aria-expanded="false">
                <span class="custom-select-val">All Counties</span>
                <svg class="custom-select-chevron" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <ul class="custom-select-list" role="listbox">
                <li class="custom-select-option is-selected" data-value="all" role="option" aria-selected="true">All Counties</li>
                {counties.map((county) => (
                  <li class="custom-select-option" data-value={county} role="option" aria-selected="false">{county}</li>
                ))}
              </ul>
            </div>
          </div>

          <!-- City dropdown -->
          <div class="filter-select-wrap">
            <span class="filter-select-label">City</span>
            <div class="custom-select" data-filter="city">
              <button class="custom-select-trigger" type="button" aria-haspopup="listbox" aria-expanded="false">
                <span class="custom-select-val">All Cities</span>
                <svg class="custom-select-chevron" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <ul class="custom-select-list" role="listbox">
                <li class="custom-select-option is-selected" data-value="all" role="option" aria-selected="true">All Cities</li>
                {cities.map((city) => (
                  <li class="custom-select-option" data-value={city} role="option" aria-selected="false">{city}</li>
                ))}
              </ul>
            </div>
          </div>

          <!-- Status dropdown -->
          <div class="filter-select-wrap">
            <span class="filter-select-label">Status</span>
            <div class="custom-select" data-filter="status">
              <button class="custom-select-trigger" type="button" aria-haspopup="listbox" aria-expanded="false">
                <span class="custom-select-val">All Statuses</span>
                <svg class="custom-select-chevron" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <ul class="custom-select-list" role="listbox">
                <li class="custom-select-option is-selected" data-value="all" role="option" aria-selected="true">All Statuses</li>
                <li class="custom-select-option" data-value="active" role="option" aria-selected="false">Available</li>
                <li class="custom-select-option" data-value="coming_soon" role="option" aria-selected="false">Coming Soon</li>
                <li class="custom-select-option" data-value="pending" role="option" aria-selected="false">Pending</li>
                <li class="custom-select-option" data-value="under_contract" role="option" aria-selected="false">Under Contract</li>
                <li class="custom-select-option" data-value="sold" role="option" aria-selected="false">Sold</li>
              </ul>
            </div>
          </div>

          <!-- Price slider -->
          <div class="filter-range-wrap">
            <p class="filter-select-label" id="price-range-label">Price Range</p>
            <div class="range-slider">
              <div class="range-track"><div class="range-fill" id="price-fill"></div></div>
              <input type="range" id="price-min" min="0" max="2000000" step="25000" value="0" class="range-input" aria-label="Minimum price" aria-labelledby="price-range-label" />
              <input type="range" id="price-max" min="0" max="2000000" step="25000" value="2000000" class="range-input" aria-label="Maximum price" />
            </div>
            <div class="filter-range-display" aria-hidden="true">
              <span id="price-min-display" class="filter-range-val">$0</span>
              <span class="filter-range-sep">–</span>
              <span id="price-max-display" class="filter-range-val">$2,000,000+</span>
            </div>
          </div>

          <!-- Square footage slider -->
          <div class="filter-range-wrap">
            <p class="filter-select-label" id="sqft-range-label">Square Feet</p>
            <div class="range-slider">
              <div class="range-track"><div class="range-fill" id="sqft-fill"></div></div>
              <input type="range" id="sqft-min" min="0" max="6000" step="100" value="0" class="range-input" aria-label="Minimum square feet" aria-labelledby="sqft-range-label" />
              <input type="range" id="sqft-max" min="0" max="6000" step="100" value="6000" class="range-input" aria-label="Maximum square feet" />
            </div>
            <div class="filter-range-display" aria-hidden="true">
              <span id="sqft-min-display" class="filter-range-val">0</span>
              <span class="filter-range-sep">–</span>
              <span id="sqft-max-display" class="filter-range-val">6,000+ sqft</span>
            </div>
          </div>

            </div>
          </div>
        </div>
      </div>

      <!-- Results count + per-page + view toggle -->
      <div class="results-bar">
        <p class="results-count" id="results-count" aria-live="polite" aria-atomic="true">
          Showing <span class="results-count-val">{listings.length}</span> propert{listings.length === 1 ? 'y' : 'ies'}
        </p>
        <div class="per-page-select">
          <span class="per-page-label">Per page</span>
          {([12, 24, 48, 96] as const).map(n => (
            <button class:list={['per-page-btn', n === 24 && 'is-active']} data-pp={n} type="button">{n}</button>
          ))}
        </div>
        <div class="view-toggle" id="view-toggle" aria-label="Toggle view">
          <button class="view-toggle-btn is-active" id="btn-grid" type="button" aria-label="Grid view" title="Grid view">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <rect x="3" y="3" width="8" height="8" rx="1"/><rect x="13" y="3" width="8" height="8" rx="1"/>
              <rect x="3" y="13" width="8" height="8" rx="1"/><rect x="13" y="13" width="8" height="8" rx="1"/>
            </svg>
          </button>
          <button class="view-toggle-btn" id="btn-list" type="button" aria-label="List view" title="List view">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <rect x="3" y="4" width="18" height="3" rx="1"/><rect x="3" y="10.5" width="18" height="3" rx="1"/><rect x="3" y="17" width="18" height="3" rx="1"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Listings container -->
      <div class="listings-grid" id="listings-grid">
        {listings.map((listing, i) => (
          <div
            class="listing-item"
            data-county={listing.county}
            data-city={listing.city}
            data-status={listing.status}
            data-price={Math.round(parseFloat(listing.list_price))}
            data-sqft={listing.sqft ?? 0}
            id={listing.slug}
          >
            <ListingCard listing={listing} index={i} />
            <ListingRow listing={listing} />
          </div>
        ))}
      </div>

      <!-- Pagination -->
      <div class="pagination" id="pagination" style="display:none">
        <button id="pg-prev" class="pg-btn" type="button" aria-label="Previous page" disabled>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <span id="pg-info" class="pg-info">Page 1 of 1</span>
        <button id="pg-next" class="pg-btn" type="button" aria-label="Next page">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
        </>
      )}
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-feature">
    <div class="cta-wrap">
      <h2 class="cta-bold-heading">Don't See the Right Home?</h2>
      <p class="cta-bold-body">
        New listings hit the market every day, and some never make it online. Tell us what you're looking for and we'll keep an eye out.
      </p>
      <div class="cta-btn-row">
        <BtnArrow href="/contact" variant="inverted">Contact Us</BtnArrow>
        <BtnArrow href="/property-search" variant="inverted">Search the MLS</BtnArrow>
      </div>
    </div>
  </section>

  {!apiError && (
  <script>
    const items         = document.querySelectorAll('.listing-item');
    const resultsCountEl = document.getElementById('results-count')!;
    const filterCountEl = document.getElementById('filter-active-count')!;

    let currentPage = 1;
    let perPage = 24;

    const sortedPrices = Array.from(items).map(el => parseFloat((el as HTMLElement).dataset.price ?? '0')).filter(p => p > 0).sort((a, b) => b - a);
    const refPrice = sortedPrices.length >= 2 ? sortedPrices[1] : (sortedPrices[0] ?? 0);
    const MAX_PRICE = refPrice > 0 ? Math.ceil(refPrice / 25000) * 25000 : 2000000;

    const highestSqft = Math.max(0, ...Array.from(items).map(el => parseFloat((el as HTMLElement).dataset.sqft ?? '0')));
    const MAX_SQFT = highestSqft > 0 ? Math.ceil(highestSqft / 500) * 500 : 6000;

    // ── Custom select state ───────────────────────────────────────────────
    const filterValues: Record<string, string> = { county: 'all', city: 'all', status: 'all' };

    function closeAll(except?: Element) {
      document.querySelectorAll('.custom-select.is-open').forEach(cs => {
        if (cs === except) return;
        cs.classList.remove('is-open');
        cs.querySelector('.custom-select-trigger')!.setAttribute('aria-expanded', 'false');
      });
    }

    document.querySelectorAll('.custom-select').forEach((cs, csIdx) => {
      const trigger  = cs.querySelector('.custom-select-trigger') as HTMLButtonElement;
      const valEl    = cs.querySelector('.custom-select-val') as HTMLElement;
      const filterId = (cs as HTMLElement).dataset.filter!;
      const opts     = Array.from(cs.querySelectorAll('.custom-select-option')) as HTMLElement[];

      opts.forEach((opt, i) => {
        opt.id = `cs-${csIdx}-opt-${i}`;
        opt.setAttribute('tabindex', '-1');
        opt.setAttribute('aria-selected', opt.classList.contains('is-selected') ? 'true' : 'false');
      });

      function selectOption(el: HTMLElement) {
        filterValues[filterId] = el.dataset.value ?? 'all';
        valEl.textContent = el.textContent;
        opts.forEach(o => { o.classList.remove('is-selected'); o.setAttribute('aria-selected', 'false'); });
        el.classList.add('is-selected');
        el.setAttribute('aria-selected', 'true');
        applyFiltersReset();
      }

      function openDropdown() {
        cs.classList.add('is-open');
        trigger.setAttribute('aria-expanded', 'true');
      }

      function focusOpt(idx: number) {
        opts[Math.max(0, Math.min(idx, opts.length - 1))].focus();
      }

      trigger.addEventListener('click', e => {
        e.stopPropagation();
        const wasOpen = cs.classList.contains('is-open');
        closeAll();
        if (!wasOpen) openDropdown();
      });

      trigger.addEventListener('keydown', e => {
        if (e.key === 'ArrowDown' || e.key === 'ArrowUp' || e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          if (!cs.classList.contains('is-open')) { closeAll(); openDropdown(); }
          const selIdx = opts.findIndex(o => o.classList.contains('is-selected'));
          focusOpt(selIdx >= 0 ? selIdx : 0);
        }
      });

      opts.forEach((opt, i) => {
        opt.addEventListener('click', e => { e.stopPropagation(); selectOption(opt); });
        opt.addEventListener('dblclick', e => { e.stopPropagation(); closeAll(); });
        opt.addEventListener('keydown', e => {
          switch (e.key) {
            case 'ArrowDown': e.preventDefault(); focusOpt(i + 1 < opts.length ? i + 1 : 0); break;
            case 'ArrowUp':   e.preventDefault(); focusOpt(i > 0 ? i - 1 : opts.length - 1); break;
            case 'Home':      e.preventDefault(); focusOpt(0); break;
            case 'End':       e.preventDefault(); focusOpt(opts.length - 1); break;
            case 'Enter':
            case ' ':         e.preventDefault(); selectOption(opt); closeAll(); trigger.focus(); break;
            case 'Escape':
            case 'Tab':       e.preventDefault(); closeAll(); trigger.focus(); break;
          }
        });
      });
    });

    document.addEventListener('click', () => closeAll());
    window.addEventListener('scroll', () => closeAll(), { passive: true });

    // ── Filter logic ──────────────────────────────────────────────────────
    let priceMin = 0, priceMax = MAX_PRICE;
    let sqftMin = 0, sqftMax = MAX_SQFT;

    const statusToShort: Record<string, string> = {
      active: 'a', coming_soon: 'c', pending: 'p', under_contract: 'u', sold: 's'
    };
    const shortToStatus: Record<string, string> = {
      a: 'active', c: 'coming_soon', p: 'pending', u: 'under_contract', s: 'sold'
    };

    function updateURL() {
      const params = new URLSearchParams();
      if (filterValues.county !== 'all') params.set('county', filterValues.county);
      if (filterValues.city   !== 'all') params.set('city',   filterValues.city);
      if (filterValues.status !== 'all') params.set('status', statusToShort[filterValues.status] ?? filterValues.status);
      if (priceMin > 0 || priceMax < MAX_PRICE)   params.set('price', `${priceMin / 1000}-${priceMax / 1000}`);
      if (sqftMin > 0 || sqftMax < MAX_SQFT)      params.set('sqft', `${sqftMin}-${sqftMax}`);
      if (perPage !== 24)    params.set('pp',   String(perPage));
      if (currentPage > 1)   params.set('page', String(currentPage));
      const qs = params.toString();
      history.replaceState(null, '', qs ? '?' + qs : window.location.pathname);
    }

    function applyFilters() {
      const matched: HTMLElement[] = [];
      items.forEach(item => {
        const el        = item as HTMLElement;
        const itemPrice = parseFloat(el.dataset.price ?? '0');
        const itemSqft  = parseFloat(el.dataset.sqft ?? '0');
        const countyOk  = filterValues.county === 'all' || el.dataset.county === filterValues.county;
        const cityOk    = filterValues.city   === 'all' || el.dataset.city   === filterValues.city;
        const statusOk  = filterValues.status === 'all' || el.dataset.status === filterValues.status;
        const priceOk   = itemPrice >= priceMin && (priceMax >= MAX_PRICE || itemPrice <= priceMax);
        const sqftOk    = itemSqft >= sqftMin && (sqftMax >= MAX_SQFT || itemSqft <= sqftMax);
        el.style.display = 'none';
        if (countyOk && cityOk && statusOk && priceOk && sqftOk) matched.push(el);
      });

      const totalPages = Math.max(1, Math.ceil(matched.length / perPage));
      if (currentPage > totalPages) currentPage = totalPages;

      const start = (currentPage - 1) * perPage;
      const end   = Math.min(start + perPage, matched.length);
      matched.slice(start, end).forEach(el => el.style.display = '');

      updateResultsCount(matched.length, start, end);
      updatePagination(totalPages);
      updateURL();
      updateFilterCount();
    }

    function applyFiltersReset() {
      currentPage = 1;
      applyFilters();
    }

    function updateResultsCount(total: number, start: number, end: number) {
      if (total === 0) {
        resultsCountEl.innerHTML = 'Showing <span class="results-count-val">0</span> properties';
      } else if (total <= perPage) {
        resultsCountEl.innerHTML = `Showing <span class="results-count-val">${total}</span> propert${total === 1 ? 'y' : 'ies'}`;
      } else {
        resultsCountEl.innerHTML = `Showing <span class="results-count-val">${start + 1}–${end}</span> of ${total} properties`;
      }
    }

    function updatePagination(totalPages: number) {
      const paginationEl = document.getElementById('pagination') as HTMLElement;
      const prevBtn      = document.getElementById('pg-prev')    as HTMLButtonElement;
      const nextBtn      = document.getElementById('pg-next')    as HTMLButtonElement;
      const infoEl       = document.getElementById('pg-info')    as HTMLElement;
      paginationEl.style.display = totalPages <= 1 ? 'none' : '';
      prevBtn.disabled = currentPage <= 1;
      nextBtn.disabled = currentPage >= totalPages;
      infoEl.textContent = `Page ${currentPage} of ${totalPages}`;
    }

    function updateFilterCount() {
      let active = 0;
      if (filterValues.county !== 'all') active++;
      if (filterValues.city   !== 'all') active++;
      if (filterValues.status !== 'all') active++;
      if (priceMin > 0 || priceMax < MAX_PRICE) active++;
      if (sqftMin > 0 || sqftMax < MAX_SQFT)    active++;
      filterCountEl.textContent = active > 0 ? String(active) : '';
      filterCountEl.classList.toggle('is-visible', active > 0);
    }

    // ── Range sliders ─────────────────────────────────────────────────────
    function updateFill(fill: HTMLElement, minEl: HTMLInputElement, maxEl: HTMLInputElement, max: number) {
      const lo = (parseFloat(minEl.value) / max) * 100;
      const hi = (parseFloat(maxEl.value) / max) * 100;
      fill.style.left  = lo + '%';
      fill.style.width = (hi - lo) + '%';
    }

    const priceMinEl  = document.getElementById('price-min')         as HTMLInputElement;
    const priceMaxEl  = document.getElementById('price-max')         as HTMLInputElement;
    const priceFill   = document.getElementById('price-fill')        as HTMLElement;
    const priceMinLbl = document.getElementById('price-min-display') as HTMLElement;
    const priceMaxLbl = document.getElementById('price-max-display') as HTMLElement;

    priceMinEl.max = String(MAX_PRICE);
    priceMaxEl.max = String(MAX_PRICE);
    priceMaxEl.value = String(MAX_PRICE);
    priceMaxLbl.textContent = '$' + MAX_PRICE.toLocaleString() + '+';

    function onPriceChange(this: HTMLInputElement) {
      let lo = parseFloat(priceMinEl.value), hi = parseFloat(priceMaxEl.value);
      if (this === priceMinEl && lo >= hi) { lo = hi - 25000; priceMinEl.value = String(lo); }
      if (this === priceMaxEl && hi <= lo) { hi = lo + 25000; priceMaxEl.value = String(hi); }
      priceMin = lo; priceMax = hi;
      priceMinLbl.textContent = '$' + lo.toLocaleString();
      priceMaxLbl.textContent = hi >= MAX_PRICE ? '$' + MAX_PRICE.toLocaleString() + '+' : '$' + hi.toLocaleString();
      updateFill(priceFill, priceMinEl, priceMaxEl, MAX_PRICE);
      applyFiltersReset();
    }
    priceMinEl.addEventListener('input', onPriceChange);
    priceMaxEl.addEventListener('input', onPriceChange);
    updateFill(priceFill, priceMinEl, priceMaxEl, MAX_PRICE);

    const sqftMinEl  = document.getElementById('sqft-min')         as HTMLInputElement;
    const sqftMaxEl  = document.getElementById('sqft-max')         as HTMLInputElement;
    const sqftFill   = document.getElementById('sqft-fill')        as HTMLElement;
    const sqftMinLbl = document.getElementById('sqft-min-display') as HTMLElement;
    const sqftMaxLbl = document.getElementById('sqft-max-display') as HTMLElement;

    sqftMinEl.max = String(MAX_SQFT);
    sqftMaxEl.max = String(MAX_SQFT);
    sqftMaxEl.value = String(MAX_SQFT);
    sqftMaxLbl.textContent = MAX_SQFT.toLocaleString() + '+ sqft';

    function onSqftChange(this: HTMLInputElement) {
      let lo = parseFloat(sqftMinEl.value), hi = parseFloat(sqftMaxEl.value);
      if (this === sqftMinEl && lo >= hi) { lo = hi - 100; sqftMinEl.value = String(lo); }
      if (this === sqftMaxEl && hi <= lo) { hi = lo + 100; sqftMaxEl.value = String(hi); }
      sqftMin = lo; sqftMax = hi;
      sqftMinLbl.textContent = lo.toLocaleString();
      sqftMaxLbl.textContent = (hi >= MAX_SQFT ? MAX_SQFT.toLocaleString() + '+' : hi.toLocaleString()) + ' sqft';
      updateFill(sqftFill, sqftMinEl, sqftMaxEl, MAX_SQFT);
      applyFiltersReset();
    }
    sqftMinEl.addEventListener('input', onSqftChange);
    sqftMaxEl.addEventListener('input', onSqftChange);
    updateFill(sqftFill, sqftMinEl, sqftMaxEl, MAX_SQFT);

    // ── Per-page selector ─────────────────────────────────────────────────
    const perPageBtns = document.querySelectorAll('.per-page-btn');

    function setPerPage(n: number) {
      perPage = n;
      perPageBtns.forEach(btn => btn.classList.toggle('is-active', parseInt((btn as HTMLElement).dataset.pp ?? '0') === n));
      localStorage.setItem('jwrg-per-page', String(n));
    }

    perPageBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        setPerPage(parseInt((btn as HTMLElement).dataset.pp ?? '24'));
        applyFiltersReset();
      });
    });

    const savedPP = parseInt(localStorage.getItem('jwrg-per-page') ?? '24');
    if ([12, 24, 48, 96].includes(savedPP)) setPerPage(savedPP);

    // ── Pagination buttons ────────────────────────────────────────────────
    document.getElementById('pg-prev')?.addEventListener('click', () => {
      if (currentPage > 1) { currentPage--; applyFilters(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
    });
    document.getElementById('pg-next')?.addEventListener('click', () => {
      currentPage++; applyFilters(); window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    // ── Initialize from URL params ────────────────────────────────────────
    (function initFromURL() {
      const params = new URLSearchParams(window.location.search);
      if (!params.toString()) return;

      const paramMap: Array<[string, string]> = [['county', 'county'], ['city', 'city'], ['status', 'status']];
      paramMap.forEach(([param, filterId]) => {
        const raw = params.get(param);
        if (!raw) return;
        const val = filterId === 'status' ? (shortToStatus[raw] ?? raw) : raw;
        const cs = document.querySelector(`.custom-select[data-filter="${filterId}"]`);
        if (!cs) return;
        const valEl   = cs.querySelector('.custom-select-val') as HTMLElement;
        const options = cs.querySelectorAll('.custom-select-option');
        options.forEach(opt => {
          const el = opt as HTMLElement;
          const isMatch = el.dataset.value === val;
          el.classList.toggle('is-selected', isMatch);
          el.setAttribute('aria-selected', isMatch ? 'true' : 'false');
          if (isMatch) valEl.textContent = el.textContent;
        });
        filterValues[filterId] = val;
      });

      const priceParam = params.get('price');
      if (priceParam) {
        const [pLo, pHi] = priceParam.split('-').map(v => parseFloat(v) * 1000);
        if (!isNaN(pLo)) { priceMin = pLo; priceMinEl.value = String(pLo); priceMinLbl.textContent = '$' + pLo.toLocaleString(); }
        if (!isNaN(pHi)) { priceMax = pHi; priceMaxEl.value = String(pHi); priceMaxLbl.textContent = '$' + pHi.toLocaleString(); }
        updateFill(priceFill, priceMinEl, priceMaxEl, MAX_PRICE);
      }

      const sqftParam = params.get('sqft');
      if (sqftParam) {
        const [sLo, sHi] = sqftParam.split('-').map(v => parseFloat(v));
        if (!isNaN(sLo)) { sqftMin = sLo; sqftMinEl.value = String(sLo); sqftMinLbl.textContent = sLo.toLocaleString(); }
        if (!isNaN(sHi)) { sqftMax = sHi; sqftMaxEl.value = String(sHi); sqftMaxLbl.textContent = sHi.toLocaleString() + ' sqft'; }
        updateFill(sqftFill, sqftMinEl, sqftMaxEl, MAX_SQFT);
      }

      const ppParam = parseInt(params.get('pp') ?? '0');
      if ([12, 24, 48, 96].includes(ppParam)) setPerPage(ppParam);
      const pageParam = parseInt(params.get('page') ?? '1');
      if (pageParam > 1) currentPage = pageParam;

      applyFilters();
    })();

    // ── Filter collapse toggle ────────────────────────────────────────────
    const filterBar     = document.getElementById('filter-bar')!;
    const filterToggle  = document.getElementById('filter-toggle') as HTMLButtonElement;
    const filterInner   = document.querySelector('.filter-collapse-inner') as HTMLElement;

    function setFilterCollapsed(collapsed: boolean, save = true, animate = true) {
      filterBar.classList.toggle('is-collapsed', collapsed);
      filterToggle.setAttribute('aria-expanded', String(!collapsed));
      if (collapsed) {
        if (animate) {
          filterInner.style.height = filterInner.scrollHeight + 'px';
          filterInner.getBoundingClientRect();
        }
        filterInner.style.overflow = 'hidden';
        filterInner.style.height = '0';
      } else {
        filterInner.style.overflow = 'hidden';
        filterInner.style.height = filterInner.scrollHeight + 'px';
        if (animate) {
          filterInner.addEventListener('transitionend', () => {
            filterInner.style.height = '';
            filterInner.style.overflow = '';
          }, { once: true });
        } else {
          filterInner.style.height = '';
          filterInner.style.overflow = '';
        }
      }
      if (save) localStorage.setItem('jwrg-filters-open', collapsed ? '0' : '1');
    }

    const savedOpen = localStorage.getItem('jwrg-filters-open');
    setFilterCollapsed(savedOpen !== '1', false, false);

    filterToggle.addEventListener('click', () => {
      setFilterCollapsed(!filterBar.classList.contains('is-collapsed'));
    });

    // ── View toggle ───────────────────────────────────────────────────────
    const grid     = document.getElementById('listings-grid') as HTMLElement;
    const btnGrid  = document.getElementById('btn-grid')  as HTMLButtonElement;
    const btnList  = document.getElementById('btn-list')  as HTMLButtonElement;

    function setView(mode: 'grid' | 'list') {
      grid.dataset.view = mode;
      btnGrid.classList.toggle('is-active', mode === 'grid');
      btnList.classList.toggle('is-active', mode === 'list');
      document.querySelectorAll<HTMLElement>('.listing-card').forEach(el => el.setAttribute('aria-hidden', mode === 'list' ? 'true' : 'false'));
      document.querySelectorAll<HTMLElement>('.listing-row').forEach(el => el.setAttribute('aria-hidden', mode === 'grid' ? 'true' : 'false'));
      localStorage.setItem('jwrg-view', mode);
    }

    const savedView = localStorage.getItem('jwrg-view') as 'grid' | 'list' | null;
    setView(savedView ?? (window.innerWidth < 1024 ? 'list' : 'grid'));

    btnGrid.addEventListener('click', () => setView('grid'));
    btnList.addEventListener('click', () => setView('list'));
  </script>
  )}
</BaseLayout>
