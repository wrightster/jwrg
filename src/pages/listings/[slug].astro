---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MiniContactForm from '../../components/MiniContactForm.astro';
import { fetchListing, formatPrice, formatAcres, formatBedsBaths, publicStatus, photoSrc } from '../../lib/api';

const { slug } = Astro.params;
const listing = slug ? await fetchListing(slug) : null;

if (!listing) {
  return Astro.redirect('/404');
}

const status = publicStatus(listing.status);
const photos = listing.photos ?? [];
const beds = formatBedsBaths(listing);
const acres = formatAcres(listing.lot_size_acres);
const title = listing.marketing_title ?? listing.address;
const documents = listing.documents ?? [];

const statusStyles: Record<string, string> = {
  available: 'bg-green-50 text-green-700 border-green-200',
  pending: 'bg-gold-50 text-gold-800 border-gold-200',
  sold: 'bg-navy-100 text-navy-700 border-navy-200',
};
---

<BaseLayout title={`${title} | Julie Wright Realty Group`} description={listing.description}>
  <section class="pt-28 pb-12">
    <div class="max-w-7xl mx-auto px-6">
      <a href="/listings" class="text-sm text-gold-600 hover:text-gold-700 inline-flex items-center gap-1 mb-6">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Back to listings
      </a>

      <div class="flex flex-wrap items-start justify-between gap-6 mb-6">
        <div>
          <div class="flex items-center gap-2 mb-3">
            <span class={`px-3 py-1 rounded-full text-xs font-semibold border ${statusStyles[status]}`}>
              {listing.status_label}
            </span>
            <span class="text-gold-600 text-xs tracking-widest uppercase">
              {listing.county} County
            </span>
          </div>
          <h1 class="font-serif text-3xl md:text-5xl text-navy-900 font-medium leading-tight">
            {title}
          </h1>
          <p class="text-navy-500 text-lg mt-2">{listing.city}, {listing.state}{listing.zip ? ` ${listing.zip}` : ''}</p>
        </div>
        <div class="text-right">
          <div class="text-3xl md:text-4xl font-serif font-bold text-navy-900">
            {formatPrice(listing.list_price)}
          </div>
          {listing.original_price && listing.original_price !== listing.list_price && (
            <div class="text-navy-400 text-sm line-through mt-1">{formatPrice(listing.original_price)}</div>
          )}
        </div>
      </div>

      <div class="flex flex-wrap gap-6 text-navy-700 mb-8 text-sm">
        {beds && <div><span class="text-navy-400">Beds/Baths: </span>{beds}</div>}
        {listing.sqft && <div><span class="text-navy-400">Square Feet: </span>{listing.sqft.toLocaleString()}</div>}
        {acres && <div><span class="text-navy-400">Acreage: </span>{acres}</div>}
        {listing.year_built && <div><span class="text-navy-400">Year Built: </span>{listing.year_built}</div>}
        {listing.mls_number && <div><span class="text-navy-400">MLS #: </span>{listing.mls_number}</div>}
      </div>
    </div>
  </section>

  {photos.length > 0 && (
    <section class="pb-12">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
          {photos.slice(0, 1).map((p) => (
            <div class="md:col-span-2 md:row-span-2 aspect-[4/3] md:aspect-auto rounded-2xl overflow-hidden">
              <img src={photoSrc(p, 1600) ?? undefined} alt={p.alt ?? p.caption ?? title} class="w-full h-full object-cover" />
            </div>
          ))}
          {photos.slice(1, 5).map((p) => (
            <div class="aspect-[4/3] rounded-2xl overflow-hidden">
              <img src={photoSrc(p, 800) ?? undefined} alt={p.alt ?? p.caption ?? title} class="w-full h-full object-cover" />
            </div>
          ))}
        </div>
        {photos.length > 5 && (
          <p class="text-center text-navy-500 mt-4 text-sm">
            + {photos.length - 5} more photos
          </p>
        )}
      </div>
    </section>
  )}

  <section class="py-12">
    <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-3 gap-12">
      <div class="lg:col-span-2 space-y-8">
        <div>
          <h2 class="font-serif text-2xl text-navy-900 font-medium mb-4">About this property</h2>
          <div class="prose prose-navy max-w-none text-navy-700 leading-relaxed whitespace-pre-line">
            {listing.full_description ?? listing.description}
          </div>
        </div>

        {listing.features.length > 0 && (
          <div>
            <h2 class="font-serif text-2xl text-navy-900 font-medium mb-4">Features</h2>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-navy-700">
              {listing.features.map((f) => (
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-gold-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  <span>{f}</span>
                </li>
              ))}
            </ul>
          </div>
        )}

        {listing.directions && (
          <div>
            <h2 class="font-serif text-2xl text-navy-900 font-medium mb-2">Directions</h2>
            <p class="text-navy-700 leading-relaxed">{listing.directions}</p>
          </div>
        )}

        {documents.length > 0 && (
          <div>
            <h2 class="font-serif text-2xl text-navy-900 font-medium mb-4">Documents</h2>
            <ul class="space-y-2">
              {documents.map((d) => (
                <li>
                  <a href={d.url ?? '#'} target="_blank" rel="noopener" class="flex items-start gap-3 p-4 rounded-lg border border-warm-200 hover:border-gold-500 hover:bg-warm-50 transition-all">
                    <svg class="w-5 h-5 text-gold-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                    <div>
                      <div class="font-semibold text-navy-900">{d.title}</div>
                      {d.description && <div class="text-navy-500 text-sm mt-0.5">{d.description}</div>}
                    </div>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>

      <aside class="space-y-6">
        <div class="bg-warm-100/60 rounded-2xl p-6 border border-warm-200/60">
          <h3 class="font-serif text-lg text-navy-900 font-semibold mb-4">Listing Agent</h3>
          {listing.agent ? (
            <>
              <div class="font-medium text-navy-900">{listing.agent.name}</div>
              <a href={`tel:${listing.agent.phone.replace(/[^0-9]/g, '')}`} class="block text-gold-700 hover:underline mt-1">
                {listing.agent.phone}
              </a>
            </>
          ) : (
            <p class="text-navy-500">Contact our office at <a href="tel:919-847-7140" class="text-gold-700 hover:underline">(919) 847-7140</a></p>
          )}
          <a
            href="/contact"
            class="block text-center w-full mt-6 py-3 bg-gold-500 hover:bg-gold-600 text-white font-semibold rounded-lg transition-all"
          >
            Request Information
          </a>
        </div>

        {listing.virtual_tour_url && (
          <a
            href={listing.virtual_tour_url}
            target="_blank"
            rel="noopener"
            class="block w-full px-6 py-3 border-2 border-navy-900 text-navy-900 hover:bg-navy-900 hover:text-white font-semibold rounded-lg text-center transition-all"
          >
            Take Virtual Tour
          </a>
        )}
      </aside>
    </div>
  </section>

  <MiniContactForm />
</BaseLayout>
