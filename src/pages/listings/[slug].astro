---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MiniContactForm from '../../components/MiniContactForm.astro';
import { fetchListing, formatPrice, formatAcres, formatBedsBaths, publicStatus, photoSrc, documentTypeLabel } from '../../lib/api';

const { slug } = Astro.params;
const listing = slug ? await fetchListing(slug) : null;

if (!listing) {
  return Astro.redirect('/404');
}

const status = publicStatus(listing.status);
const photos = listing.photos ?? [];
const beds = formatBedsBaths(listing);
const acres = formatAcres(listing.lot_size_acres);
const title = listing.marketing_title ?? listing.address;
const documents = (listing.documents ?? [])
  .filter((d) => d.url)
  .sort((a, b) => a.sort_order - b.sort_order);
const today = new Date();
function expiryState(iso: string | null): { label: string; tone: 'warn' | 'ok' } | null {
  if (!iso) return null;
  const expires = new Date(iso);
  const days = Math.round((expires.getTime() - today.getTime()) / (1000 * 60 * 60 * 24));
  if (days < 0) return { label: `Expired ${expires.toLocaleDateString()}`, tone: 'warn' };
  if (days <= 30) return { label: `Expires in ${days} days`, tone: 'warn' };
  return { label: `Valid through ${expires.toLocaleDateString()}`, tone: 'ok' };
}

const totalImages = photos.length;
const heroSrcs = photos.slice(0, 5).map((p, i) => photoSrc(p, i === 0 ? 1600 : 800));
const lightboxSrcs = photos.map((p) => photoSrc(p, 1600));
const thumbSrcs = photos.map((p) => photoSrc(p, 400));

const statusStyles: Record<string, string> = {
  available: 'bg-green-50 text-green-700 border-green-200',
  pending: 'bg-gold-50 text-gold-800 border-gold-200',
  sold: 'bg-navy-100 text-navy-700 border-navy-200',
};
---

<BaseLayout title={`${title} | Julie Wright Realty Group`} description={listing.description}>
  <section class="pt-28 pb-12">
    <div class="max-w-7xl mx-auto px-6">
      <a href="/listings" class="text-sm text-gold-600 hover:text-gold-700 inline-flex items-center gap-1 mb-6">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Back to listings
      </a>

      <div class="flex flex-wrap items-start justify-between gap-6 mb-6">
        <div>
          <div class="flex items-center gap-2 mb-3">
            <span class={`px-3 py-1 rounded-full text-xs font-semibold border ${statusStyles[status]}`}>
              {listing.status_label}
            </span>
            <span class="text-gold-600 text-xs tracking-widest uppercase">
              {listing.county} County
            </span>
          </div>
          <h1 class="font-serif text-3xl md:text-5xl text-navy-900 font-medium leading-tight">
            {title}
          </h1>
          <p class="text-navy-500 text-lg mt-2">{listing.city}, {listing.state}{listing.zip ? ` ${listing.zip}` : ''}</p>
        </div>
        <div class="text-right">
          <div class="text-3xl md:text-4xl font-serif font-bold text-navy-900">
            {formatPrice(listing.list_price)}
          </div>
          {listing.original_price && listing.original_price !== listing.list_price && (
            <div class="text-navy-400 text-sm line-through mt-1">{formatPrice(listing.original_price)}</div>
          )}
        </div>
      </div>

      <div class="flex flex-wrap gap-6 text-navy-700 mb-8 text-sm">
        {beds && <div><span class="text-navy-400">Beds/Baths: </span>{beds}</div>}
        {listing.sqft && <div><span class="text-navy-400">Square Feet: </span>{listing.sqft.toLocaleString()}</div>}
        {acres && <div><span class="text-navy-400">Acreage: </span>{acres}</div>}
        {listing.year_built && <div><span class="text-navy-400">Year Built: </span>{listing.year_built}</div>}
        {listing.mls_number && <div><span class="text-navy-400">MLS #: </span>{listing.mls_number}</div>}
      </div>
    </div>
  </section>

  {totalImages > 0 && (
    <section class="pb-12">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
          {heroSrcs.slice(0, 1).map((src, i) => (
            <button
              type="button"
              class="gallery-tile md:col-span-2 md:row-span-2 aspect-[4/3] md:aspect-auto rounded-2xl overflow-hidden relative group"
              data-lb-index={i}
              aria-label={`View photo ${i + 1} of ${totalImages}`}
            >
              <img src={src ?? undefined} alt={photos[i].alt ?? photos[i].caption ?? title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]" />
            </button>
          ))}
          {heroSrcs.slice(1, 5).map((src, i) => (
            <button
              type="button"
              class="gallery-tile aspect-[4/3] rounded-2xl overflow-hidden relative group"
              data-lb-index={i + 1}
              aria-label={`View photo ${i + 2} of ${totalImages}`}
            >
              <img src={src ?? undefined} alt={photos[i + 1].alt ?? photos[i + 1].caption ?? title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]" />
              {i === 3 && totalImages > 5 && (
                <div class="absolute inset-0 bg-navy-950/60 flex flex-col items-center justify-center text-warm-50">
                  <svg class="w-8 h-8 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.41a2.25 2.25 0 013.182 0l2.909 2.91M3.75 21h16.5a2.25 2.25 0 002.25-2.25V5.25a2.25 2.25 0 00-2.25-2.25H3.75a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 003.75 21z"/></svg>
                  <span class="font-semibold">+ {totalImages - 5} more</span>
                </div>
              )}
            </button>
          ))}
        </div>
        {totalImages > 1 && (
          <div class="flex justify-center mt-6">
            <button
              type="button"
              id="view-all-photos"
              class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border-2 border-navy-900 text-navy-900 hover:bg-navy-900 hover:text-warm-50 font-semibold transition-all text-sm"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.41a2.25 2.25 0 013.182 0l2.909 2.91M3.75 21h16.5a2.25 2.25 0 002.25-2.25V5.25a2.25 2.25 0 00-2.25-2.25H3.75a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 003.75 21z"/></svg>
              View all {totalImages} photos
            </button>
          </div>
        )}
      </div>
    </section>
  )}

  <section class="py-12">
    <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-3 gap-12">
      <div class="lg:col-span-2 space-y-8">
        <div>
          <h2 class="font-serif text-2xl text-navy-900 font-medium mb-4">About this property</h2>
          <div class="prose prose-navy max-w-none text-navy-700 leading-relaxed whitespace-pre-line">
            {listing.full_description ?? listing.description}
          </div>
        </div>

        {listing.features.length > 0 && (
          <div>
            <h2 class="font-serif text-2xl text-navy-900 font-medium mb-4">Features</h2>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-navy-700">
              {listing.features.map((f) => (
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-gold-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  <span>{f}</span>
                </li>
              ))}
            </ul>
          </div>
        )}

        {listing.directions && (
          <div>
            <h2 class="font-serif text-2xl text-navy-900 font-medium mb-2">Directions</h2>
            <p class="text-navy-700 leading-relaxed">{listing.directions}</p>
          </div>
        )}

        {documents.length > 0 && (
          <div>
            <h2 class="font-serif text-2xl text-navy-900 font-medium mb-1">Documents</h2>
            <p class="text-navy-500 text-sm mb-4">Public materials available for this property — surveys, plats, HOA documents, inspection reports, and more.</p>
            <ul class="space-y-3">
              {documents.map((d) => {
                const expiry = expiryState(d.expires_at);
                return (
                  <li>
                    <a href={d.url!} target="_blank" rel="noopener" class="group flex items-start gap-4 p-4 rounded-xl border border-warm-200 hover:border-gold-500 hover:bg-warm-50/60 transition-all">
                      <svg class="w-6 h-6 text-gold-600 mt-1 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                      </svg>
                      <div class="flex-1 min-w-0">
                        <div class="flex flex-wrap items-baseline gap-2">
                          <span class="font-semibold text-navy-900 group-hover:text-gold-700">{d.title}</span>
                          <span class="text-[11px] tracking-wider uppercase font-medium text-gold-700 bg-gold-50 border border-gold-100 rounded-full px-2 py-0.5">
                            {documentTypeLabel(d.document_type)}
                          </span>
                        </div>
                        {d.description && <div class="text-navy-500 text-sm mt-1">{d.description}</div>}
                        {expiry && (
                          <div class={`text-xs mt-1.5 ${expiry.tone === 'warn' ? 'text-red-600 font-medium' : 'text-navy-400'}`}>
                            {expiry.label}
                          </div>
                        )}
                      </div>
                      <svg class="w-4 h-4 text-navy-400 group-hover:text-gold-600 mt-1.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                      </svg>
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        )}
      </div>

      <aside class="space-y-6">
        <div class="bg-warm-100/60 rounded-2xl p-6 border border-warm-200/60">
          <h3 class="font-serif text-lg text-navy-900 font-semibold mb-4">Listing Agent</h3>
          {listing.agent ? (
            <>
              <div class="font-medium text-navy-900">{listing.agent.name}</div>
              <a href={`tel:${listing.agent.phone.replace(/[^0-9]/g, '')}`} class="block text-gold-700 hover:underline mt-1">
                {listing.agent.phone}
              </a>
            </>
          ) : (
            <p class="text-navy-500">Contact our office at <a href="tel:919-847-7140" class="text-gold-700 hover:underline">(919) 847-7140</a></p>
          )}
          <a
            href="/contact"
            class="block text-center w-full mt-6 py-3 bg-gold-500 hover:bg-gold-600 text-white font-semibold rounded-lg transition-all"
          >
            Request Information
          </a>
        </div>

        {listing.virtual_tour_url && (
          <a
            href={listing.virtual_tour_url}
            target="_blank"
            rel="noopener"
            class="block w-full px-6 py-3 border-2 border-navy-900 text-navy-900 hover:bg-navy-900 hover:text-white font-semibold rounded-lg text-center transition-all"
          >
            Take Virtual Tour
          </a>
        )}
      </aside>
    </div>
  </section>

  <MiniContactForm listingId={listing.id} />

  {totalImages > 0 && (
    <div
      id="lightbox"
      class="lightbox"
      role="dialog"
      aria-modal="true"
      aria-label="Property photo gallery"
    >
      <img id="lb-bg" src="" alt="" aria-hidden="true" class="lightbox-bg" />
      <div class="lightbox-overlay"></div>

      <button id="lb-close" class="lightbox-close" aria-label="Close gallery">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
      </button>

      {totalImages > 1 && (
        <>
          <button id="lb-prev" class="lightbox-prev" aria-label="Previous image">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-10 h-10 pointer-events-none"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
          </button>
          <button id="lb-next" class="lightbox-next" aria-label="Next image">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-10 h-10 pointer-events-none"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
          </button>
        </>
      )}

      <div class="lightbox-body">
        <img id="lb-image" src="" alt="" class="lightbox-img" />
      </div>

      <div class="lightbox-counter" id="lb-counter"></div>
    </div>
  )}

  <style>
    .gallery-tile {
      cursor: pointer;
    }
    .gallery-tile:focus-visible {
      outline: 2px solid var(--color-gold-500);
      outline-offset: 4px;
    }

    .lightbox {
      position: fixed;
      inset: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: center;
      padding-top: 5rem;
      backdrop-filter: blur(12px);
      opacity: 0;
      pointer-events: none;
      transition: opacity 300ms ease;
    }
    .lightbox.is-open {
      opacity: 1;
      pointer-events: auto;
    }
    .lightbox-bg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0.45;
      filter: blur(28px);
      z-index: 0;
      transition: opacity 200ms ease;
    }
    .lightbox-overlay {
      position: absolute;
      inset: 0;
      background-color: oklch(from var(--color-navy-950) l c h / 0.6);
      z-index: 1;
    }
    .lightbox::after {
      content: '';
      position: absolute;
      inset: 0;
      pointer-events: none;
      background: radial-gradient(ellipse at center, transparent 40%, oklch(from var(--color-navy-950) l c h / 0.85) 100%);
      z-index: 2;
    }
    .lightbox-close {
      position: absolute;
      top: 1rem;
      right: 1rem;
      z-index: 10;
      width: 3rem;
      height: 3rem;
      display: flex;
      align-items: center;
      justify-content: center;
      color: oklch(from var(--color-warm-50) l c h / 0.7);
      transition: color 200ms ease;
    }
    .lightbox-close:hover {
      color: var(--color-warm-50);
    }
    .lightbox-prev,
    .lightbox-next {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      z-index: 20;
      width: 4rem;
      height: 4rem;
      display: flex;
      align-items: center;
      justify-content: center;
      background-color: oklch(from var(--color-warm-50) l c h / 0.95);
      color: var(--color-navy-900);
      border-radius: 9999px;
      transition: all 200ms ease;
      cursor: pointer;
      opacity: 0.6;
    }
    .lightbox-prev:hover,
    .lightbox-next:hover {
      background-color: var(--color-gold-500);
      color: var(--color-warm-50);
      opacity: 1;
    }
    .lightbox-prev { left: 1.5rem; }
    .lightbox-next { right: 1.5rem; }
    .lightbox-body {
      position: relative;
      z-index: 10;
      max-width: 80rem;
      max-height: 85vh;
      margin: 0 auto;
      padding: 0 6rem;
    }
    .lightbox-img {
      max-width: 100%;
      max-height: 85vh;
      object-fit: contain;
      margin: 0 auto;
      transition: opacity 250ms ease;
    }
    .lightbox-counter {
      position: absolute;
      bottom: 1.5rem;
      left: 50%;
      transform: translateX(-50%);
      z-index: 10;
      color: oklch(from var(--color-warm-50) l c h / 0.7);
      font-size: 0.875rem;
      font-variant-numeric: tabular-nums;
    }

    @media (max-width: 767px) {
      .lightbox-body {
        padding-left: 1rem;
        padding-right: 1rem;
        padding-bottom: 8rem;
      }
      .lightbox-prev,
      .lightbox-next {
        width: 3rem;
        height: 3rem;
        top: auto;
        bottom: 2rem;
      }
      .lightbox-prev {
        left: 50%;
        transform: translateX(-4.5rem);
      }
      .lightbox-next {
        left: 50%;
        right: auto;
        transform: translateX(1.5rem);
      }
      .lightbox-counter {
        bottom: 5.5rem;
      }
    }
  </style>

  {totalImages > 0 && (
    <script define:vars={{ lightboxSrcs, totalImages }}>
      let currentIndex = 0;
      let trigger = null;

      const lightbox = document.getElementById('lightbox');
      const lbImage = document.getElementById('lb-image');
      const lbBg = document.getElementById('lb-bg');
      const lbCounter = document.getElementById('lb-counter');
      const lbClose = document.getElementById('lb-close');
      const lbPrev = document.getElementById('lb-prev');
      const lbNext = document.getElementById('lb-next');

      function setLightboxImage(i) {
        currentIndex = i;
        const src = lightboxSrcs[i];
        if (lbImage) {
          lbImage.style.opacity = '0';
          setTimeout(() => {
            lbImage.src = src;
            lbImage.alt = `Photo ${i + 1} of ${totalImages}`;
            lbImage.style.opacity = '1';
          }, 120);
        }
        if (lbBg) {
          lbBg.style.opacity = '0';
          setTimeout(() => {
            lbBg.src = src;
            lbBg.style.opacity = '0.45';
          }, 120);
        }
        if (lbCounter) lbCounter.textContent = `${i + 1} / ${totalImages}`;
      }

      function openLightbox(index, source) {
        trigger = source ?? null;
        setLightboxImage(index);
        lightbox?.classList.add('is-open');
        document.body.style.overflow = 'hidden';
        lbClose?.focus();
      }

      function closeLightbox() {
        lightbox?.classList.remove('is-open');
        document.body.style.overflow = '';
        trigger?.focus();
        trigger = null;
      }

      function next() { setLightboxImage((currentIndex + 1) % totalImages); }
      function prev() { setLightboxImage((currentIndex - 1 + totalImages) % totalImages); }

      document.querySelectorAll('.gallery-tile').forEach((tile) => {
        tile.addEventListener('click', () => {
          const idx = parseInt(tile.getAttribute('data-lb-index') ?? '0', 10);
          openLightbox(idx, tile);
        });
      });

      const viewAll = document.getElementById('view-all-photos');
      if (viewAll) {
        viewAll.addEventListener('click', () => openLightbox(0, viewAll));
      }

      lbClose?.addEventListener('click', closeLightbox);
      lbPrev?.addEventListener('click', prev);
      lbNext?.addEventListener('click', next);

      lightbox?.addEventListener('click', (e) => {
        if (!e.target.closest('button, .lightbox-body, .lightbox-counter')) {
          closeLightbox();
        }
      });

      document.addEventListener('keydown', (e) => {
        if (!lightbox?.classList.contains('is-open')) return;
        if (e.key === 'Escape') { closeLightbox(); return; }
        if (e.key === 'ArrowRight') { next(); return; }
        if (e.key === 'ArrowLeft') { prev(); return; }
        if (e.key === 'Tab') {
          e.preventDefault();
          const focusable = [lbClose, lbPrev, lbNext].filter(Boolean);
          const idx = focusable.indexOf(document.activeElement);
          const nextIdx = e.shiftKey
            ? (idx - 1 + focusable.length) % focusable.length
            : (idx + 1) % focusable.length;
          focusable[nextIdx].focus();
        }
      });

      let swipeStartX = 0;
      let swipeStartY = 0;
      lightbox?.addEventListener('touchstart', (e) => {
        swipeStartX = e.touches[0].clientX;
        swipeStartY = e.touches[0].clientY;
      }, { passive: true });
      lightbox?.addEventListener('touchend', (e) => {
        const dx = e.changedTouches[0].clientX - swipeStartX;
        const dy = e.changedTouches[0].clientY - swipeStartY;
        if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 40) {
          if (dx < 0) next(); else prev();
        }
      }, { passive: true });
    </script>
  )}
</BaseLayout>
