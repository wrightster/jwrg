---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageBanner from '../components/PageBanner.astro';
import Form from '../components/Form.astro';
import type { Field } from '../lib/formFields';

export const prerender = true;

const fields: Field[] = [
  { type: 'text', name: 'name', label: 'Name', required: true, cols: 1 },
  { type: 'tel', name: 'phone', label: 'Phone', required: true, cols: 1 },
  { type: 'email', name: 'email', label: 'Email', required: true, cols: 2 },
  { type: 'textarea', name: 'message', label: 'How can we help?', required: true, rows: 5, cols: 2 },
  {
    type: 'checkbox',
    name: 'opt_in',
    label: 'I give Julie Wright Realty Group permission to contact me via email, phone, or text.',
    cols: 2,
  },
];

const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent('10931 Strickland Rd Ste 111 Raleigh NC 27615')}`;
---

<BaseLayout title="Contact Us | Julie Wright Realty Group">
  <PageBanner
    label="Get in Touch"
    title="Have a Question About Real Estate in the Triangle?"
    description="Whether you're buying, selling, relocating, or just exploring your options, our team is here to help."
  />

  <section class="py-20">
    <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-12">
      <div class="space-y-10">
        <div>
          <div class="text-gold-600 text-sm font-medium tracking-widest uppercase mb-3">Office</div>
          <h2 class="font-serif text-3xl text-navy-900 font-medium mb-6">Stop By or Reach Out</h2>

          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-gold-50 text-gold-600 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
              <div>
                <div class="font-semibold text-navy-900 mb-1">Office</div>
                <p class="text-navy-500">
                  10931 Strickland Rd, Ste 111<br />
                  Raleigh, NC 27615
                </p>
                <a href={mapsUrl} target="_blank" rel="noopener" class="text-gold-700 hover:underline text-sm mt-1 inline-block">
                  View on Google Maps →
                </a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-gold-50 text-gold-600 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              </div>
              <div>
                <div class="font-semibold text-navy-900 mb-1">Phone</div>
                <a href="tel:919-847-7140" class="text-navy-500 hover:text-gold-600 transition-colors block">(919) 847-7140</a>
                <div class="text-navy-400 text-sm">Fax (919) 847-7182</div>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-gold-50 text-gold-600 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
              <div>
                <div class="font-semibold text-navy-900 mb-1">Email</div>
                <a href="mailto:info@juliewrightrealtygroup.com" class="text-navy-500 hover:text-gold-600 transition-colors">info@juliewrightrealtygroup.com</a>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-warm-100/60 border border-warm-200 rounded-2xl p-6">
          <h3 class="font-serif text-lg text-navy-900 font-semibold mb-2">Protecting Your Right To Privacy</h3>
          <p class="text-navy-500 text-sm leading-relaxed">
            We respect your privacy. Information you submit is used solely to respond to your inquiry. We never sell or share your information with third parties.
            <a href="/privacy" class="text-gold-700 hover:underline">Read our privacy policy →</a>
          </p>
        </div>
      </div>

      <div>
        <Form
          formKey="contact"
          title="Send Us a Message"
          submitLabel="Send Message"
          fields={fields}
        />
      </div>
    </div>
  </section>
</BaseLayout>
