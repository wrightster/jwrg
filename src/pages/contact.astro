---
import BaseLayout from '../layouts/BaseLayout.astro';
import Form from '../components/Form.astro';
import { site } from '../data/site';
import type { Field } from '../lib/formFields';

export const prerender = true;

const fields: Field[] = [
  { type: 'text', name: 'name', label: 'Name', required: true, cols: 1 },
  { type: 'tel', name: 'phone', label: 'Phone', required: true, cols: 1 },
  { type: 'email', name: 'email', label: 'Email', required: true, cols: 2 },
  { type: 'textarea', name: 'message', label: 'How can we help?', required: true, rows: 5, cols: 2 },
];

const addressText = `${site.address.street1} ${site.address.street2} ${site.address.city} ${site.address.state} ${site.address.zip}`;
const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(addressText)}`;
---

<BaseLayout title="Contact — Julie Wright Realty Group" description="Get in touch with Julie Wright Realty Group. Buying, selling, relocating, or just exploring — we're here to help.">
  <!-- Page Header -->
  <section class="page-banner">
    <div class="content-wrap">
      <h1 class="page-banner-title">Get In Touch</h1>
      <p class="page-banner-desc">
        Whether you're buying, selling, relocating, or just exploring your options — we're here to help.
      </p>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="contact-section">
    <div class="content-wrap">
      <div class="contact-grid">
        <!-- Contact Form -->
        <div class="contact-form-col">
          <Form
            formKey="contact"
            title="Send Us a Message"
            description="Fill out the form below and we'll get back to you within one business day."
            submitLabel="Send Message"
            fields={fields}
          />
        </div>

        <!-- Sidebar -->
        <div class="contact-sidebar">
          <!-- Office -->
          <div class="sidebar-card">
            <h3 class="sidebar-card-heading">Office</h3>
            <address class="sidebar-address">
              <div class="sidebar-address-row">
                <svg class="sidebar-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                </svg>
                <div>
                  <p class="sidebar-address-name">{site.name}</p>
                  <p>{site.address.street1}, {site.address.street2}</p>
                  <p>{site.address.city}, {site.address.state} {site.address.zip}</p>
                  <a href={mapsUrl} target="_blank" rel="noopener" class="sidebar-contact-link text-red-600 text-sm mt-1 inline-block">View on Google Maps →</a>
                </div>
              </div>
              <div class="sidebar-address-row--center">
                <svg class="sidebar-icon--center" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                </svg>
                <a href={`tel:${site.phoneRaw}`} class="sidebar-contact-link">{site.phone}</a>
              </div>
              <div class="sidebar-address-row--center">
                <svg class="sidebar-icon--center" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                </svg>
                <span>Fax: {site.fax}</span>
              </div>
              <div class="sidebar-address-row--center">
                <svg class="sidebar-icon--center" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                </svg>
                <a href={`mailto:${site.email}`} class="sidebar-contact-link">{site.email}</a>
              </div>
            </address>
          </div>

          <!-- Privacy -->
          <div class="sidebar-card">
            <h3 class="sidebar-card-heading">Your Privacy</h3>
            <p class="sidebar-area-desc">
              We respect your privacy. Information you submit is used solely to respond to your inquiry — we never sell or share it.
            </p>
            <a href="/privacy" class="sidebar-contact-link text-red-600 text-sm">Read our privacy policy →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Area CTA -->
  <section class="cta-red">
    <div class="cta-wrap">
      <h2 class="cta-dark-heading">Serving the Triangle Region</h2>
      <p class="cta-dark-body text-earth-100">We help families buy and sell across these North Carolina counties.</p>
      <div class="flex flex-wrap justify-center gap-2 mt-8">
        {site.counties.map((county) => (
          <a href={`/listings?county=${encodeURIComponent(county)}`} class="sidebar-county-tag">{county}</a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
