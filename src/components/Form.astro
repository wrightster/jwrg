---
// A flexible single-column form runner. Pass a `formKey` from data/forms.ts
// and a list of `fields` describing each input. The form posts JSON to the
// office API via lib/api.ts submitForm().
import { formIds, type FormKey } from '../data/forms';
import type { Field } from '../lib/formFields';

interface Props {
  formKey: FormKey;
  title?: string;
  description?: string;
  submitLabel?: string;
  fields: Field[];
  legalNote?: string;
}

const {
  formKey,
  title,
  description,
  submitLabel = 'Submit',
  fields,
  legalNote = 'By submitting this form, you are giving Julie Wright Realty Group permission to contact you via email, phone, or text.',
} = Astro.props;

const formId = formIds[formKey];
---

<div class="bg-white rounded-sm p-8 md:p-10">
  {title && <h3 class="contact-form-heading">{title}</h3>}
  {description && <p class="contact-form-desc">{description}</p>}

  <form class="form-stack" data-jwrg-form data-form-id={formId ?? ''}>
    <div class="form-row-2">
      {fields.map((field) => {
        const span = field.cols === 1 ? 'sm:col-span-1' : 'form-col-2';
        const id = `f-${formKey}-${field.name}`;
        if (field.type === 'textarea') {
          return (
            <div class={span}>
              <label for={id} class="form-label">
                {field.label}{field.required && ' *'}
              </label>
              <textarea
                id={id}
                name={field.name}
                rows={field.rows ?? 4}
                required={field.required}
                placeholder={field.placeholder}
                class="form-textarea"
              ></textarea>
            </div>
          );
        }
        if (field.type === 'select') {
          return (
            <div class={span}>
              <label for={id} class="form-label">
                {field.label}{field.required && ' *'}
              </label>
              <select id={id} name={field.name} required={field.required} class="form-input">
                <option value="">Select…</option>
                {field.options.map((opt) => <option value={opt}>{opt}</option>)}
              </select>
            </div>
          );
        }
        if (field.type === 'checkbox') {
          return (
            <div class={span}>
              <label class="flex items-start gap-3 text-sm text-earth-700">
                <input
                  id={id}
                  name={field.name}
                  type="checkbox"
                  class="mt-1 w-4 h-4 rounded-sm border-earth-300 text-red-600 focus:ring-red-600/30"
                />
                <span>{field.label}</span>
              </label>
            </div>
          );
        }
        return (
          <div class={span}>
            <label for={id} class="form-label">
              {field.label}{field.required && ' *'}
            </label>
            <input
              type={field.type}
              id={id}
              name={field.name}
              required={field.required}
              placeholder={field.placeholder}
              class="form-input"
            />
          </div>
        );
      })}
    </div>

    <input type="text" name="website" tabindex="-1" autocomplete="off" class="sr-only" aria-hidden="true" />

    {legalNote && (
      <p class="text-earth-400 text-xs leading-relaxed">{legalNote}</p>
    )}

    <button
      type="submit"
      class="w-full py-3 font-display font-medium border-2 border-red-600 bg-red-600 text-earth-50 tracking-wide rounded-sm transition-all duration-300 hover:bg-red-700 hover:border-red-700 cursor-pointer"
    >
      {submitLabel}
    </button>
    <p data-form-status class="text-sm hidden"></p>
  </form>
</div>

<script>
  import { submitForm } from '../lib/api';

  document.querySelectorAll<HTMLFormElement>('form[data-jwrg-form]').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const status = form.querySelector<HTMLElement>('[data-form-status]');
      const button = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      if (!button || !status) return;

      button.disabled = true;
      const originalText = button.textContent;
      button.textContent = 'Sending…';
      status.classList.add('hidden');

      const formId = form.dataset.formId || null;
      const data: Record<string, unknown> = {};
      new FormData(form).forEach((value, key) => {
        if (data[key] !== undefined) {
          if (Array.isArray(data[key])) (data[key] as unknown[]).push(value);
          else data[key] = [data[key], value];
        } else {
          data[key] = value;
        }
      });

      const result = await submitForm(formId, data);

      status.classList.remove('hidden');
      status.textContent = result.message;
      status.className = result.ok
        ? 'text-sm text-red-700'
        : 'text-sm text-red-600';

      button.disabled = false;
      button.textContent = originalText;
      if (result.ok) form.reset();
    });
  });
</script>
