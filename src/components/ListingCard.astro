---
import { type ApiListing, formatPrice, formatAcres, formatBedsBaths, publicStatus, photoSrc } from '../lib/api';

interface Props {
  listing: ApiListing;
}

const { listing } = Astro.props;
const status = publicStatus(listing.status);
const photo = photoSrc(listing.primary_photo, 800);

const statusStyles: Record<string, string> = {
  available: 'bg-green-50 text-green-700 border-green-200',
  pending: 'bg-gold-50 text-gold-800 border-gold-200',
  sold: 'bg-navy-100 text-navy-700 border-navy-200',
};

const beds = formatBedsBaths(listing);
const acres = formatAcres(listing.lot_size_acres);
const title = listing.marketing_title ?? listing.address;
---

<a
  href={`/listings/${listing.slug}`}
  class="group relative bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl hover:shadow-navy-900/8 transition-all duration-500 hover:-translate-y-1 border border-warm-200/50 flex flex-col"
>
  <div class="aspect-[4/3] overflow-hidden relative bg-warm-100">
    {photo ? (
      <img
        src={photo}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center text-navy-300">
        <svg class="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      </div>
    )}
    <div class="absolute top-4 left-4 flex gap-2">
      <span class={`px-3 py-1 rounded-full text-xs font-semibold border backdrop-blur-sm ${statusStyles[status]}`}>
        {listing.status_label}
      </span>
      {listing.featured && (
        <span class="px-3 py-1 rounded-full text-xs font-semibold border bg-gold-500/90 text-white border-gold-400 backdrop-blur-sm">
          Featured
        </span>
      )}
    </div>
    {acres && (
      <div class="absolute bottom-4 right-4 px-3 py-1.5 rounded-lg text-xs font-semibold bg-navy-900/80 text-white backdrop-blur-sm">
        {acres}
      </div>
    )}
  </div>

  <div class="p-6 flex-1 flex flex-col">
    <div class="text-gold-600 text-xs tracking-widest uppercase mb-1">{listing.county} County</div>
    <h3 class="font-serif text-lg font-semibold text-navy-900 group-hover:text-gold-700 transition-colors line-clamp-2">
      {title}
    </h3>
    <p class="text-navy-500 text-sm mt-1">{listing.city}, {listing.state}</p>

    {beds && <p class="text-navy-700 text-sm mt-3">{beds}</p>}

    <p class="text-navy-500 text-sm mt-3 line-clamp-2 leading-relaxed flex-1">
      {listing.description}
    </p>

    <div class="mt-4 pt-4 border-t border-warm-200/60 flex items-center justify-between">
      <div class="text-xl font-serif font-bold text-navy-900">{formatPrice(listing.list_price)}</div>
      <div class="text-gold-600 text-sm font-medium flex items-center gap-1">
        View Details
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </div>
    </div>
  </div>
</a>
