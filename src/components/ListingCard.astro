---
// Site-specific wrapper around the shared ListingCard — injects JWRG's
// headline (beds/baths/sqft for residential). All structural markup lives
// in @jw/shared/components/ListingCard.astro.

import SharedListingCard from '@jw/shared/components/ListingCard.astro';
import { formatBedsBaths, formatSqft, type ApiListing } from '../lib/api';

interface Props {
  listing: ApiListing;
  index?: number;
}

const { listing, index } = Astro.props;
const headline =
  formatBedsBaths(listing) ||
  formatSqft(listing.sqft) ||
  `${listing.city}, ${listing.state}`;
---

<SharedListingCard listing={listing} index={index} headline={headline} />
