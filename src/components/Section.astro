---
interface Props {
  label?: string;
  heading?: string;
  description?: string;
  variant?: 'light' | 'warm' | 'dark';
  align?: 'left' | 'center';
  class?: string;
}

const {
  label,
  heading,
  description,
  variant = 'light',
  align = 'center',
  class: className = '',
} = Astro.props;

const bgMap = {
  light: '',
  warm: 'bg-earth-100/40',
  dark: 'bg-earth-900 text-light-text',
};

const headingColor = variant === 'dark' ? 'text-light-text' : 'text-earth-900';
const bodyColor = variant === 'dark' ? 'text-earth-300' : 'text-earth-600';
---

<section class={`py-12 lg:py-16 relative ${bgMap[variant]} ${className}`}>
  <div class="content-wrap">
    {(label || heading || description) && (
      <div class={`max-w-2xl mb-12 ${align === 'center' ? 'mx-auto text-center' : ''}`}>
        {label && <p class="section-label">{label}</p>}
        {heading && (
          <h2 class={`section-heading ${headingColor}`}>{heading}</h2>
        )}
        {description && (
          <p class={`${bodyColor} leading-relaxed mt-4`}>{description}</p>
        )}
      </div>
    )}
    <slot />
  </div>
</section>
