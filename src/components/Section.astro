---
interface Props {
  label?: string;
  heading?: string;
  description?: string;
  variant?: 'light' | 'warm' | 'dark';
  align?: 'left' | 'center';
  class?: string;
}

const {
  label,
  heading,
  description,
  variant = 'light',
  align = 'center',
  class: className = '',
} = Astro.props;

const bgMap = {
  light: 'bg-white',
  warm: 'bg-warm-100/50',
  dark: 'bg-navy-900 text-white',
};

const labelColor = variant === 'dark' ? 'text-gold-400' : 'text-gold-600';
const headingColor = variant === 'dark' ? 'text-white' : 'text-navy-900';
const bodyColor = variant === 'dark' ? 'text-navy-300' : 'text-navy-500';
---

<section class={`py-24 lg:py-32 ${bgMap[variant]} ${className}`}>
  <div class="max-w-7xl mx-auto px-6">
    {(label || heading || description) && (
      <div class={`max-w-2xl mb-16 ${align === 'center' ? 'mx-auto text-center' : ''}`}>
        {label && (
          <div class={`${labelColor} font-medium text-sm tracking-widest uppercase mb-3`}>
            {label}
          </div>
        )}
        {heading && (
          <h2 class={`font-serif text-3xl md:text-4xl ${headingColor} font-medium mb-4`}>
            {heading}
          </h2>
        )}
        {description && (
          <p class={`${bodyColor} leading-relaxed`}>{description}</p>
        )}
      </div>
    )}
    <slot />
  </div>
</section>
