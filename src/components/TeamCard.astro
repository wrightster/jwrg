---
import type { ApiTeamMember } from '../lib/api';
import { photoSrc } from '../lib/api';

interface Props {
  member: ApiTeamMember;
}

const { member } = Astro.props;
const photo = photoSrc(member.primary_photo, 800);
const summary = member.short_bio ?? member.bio ?? '';
const phone = member.public_phone ?? '';
const email = member.public_email ?? '';
---

<a
  href={`/about/team/${member.slug}`}
  class="group relative flex flex-col bg-white rounded-sm overflow-hidden ring-1 ring-inset ring-earth-100 hover:ring-2 hover:ring-red-600 transition-all duration-300"
>
  <div class="aspect-[4/5] overflow-hidden bg-earth-100">
    {photo ? (
      <img
        src={photo}
        alt={member.primary_photo?.alt ?? member.name}
        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center text-earth-400">
        <svg class="w-20 h-20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
      </div>
    )}
  </div>
  <div class="p-6 flex-1 flex flex-col">
    <h3 class="font-display text-xl text-earth-900 transition-colors duration-300 group-hover:text-red-600">{member.name}</h3>
    {member.title && <p class="text-xs uppercase tracking-widest text-red-600 font-semibold mt-1">{member.title}</p>}
    {summary && <p class="text-earth-600 text-sm mt-3 line-clamp-3 flex-1">{summary}</p>}
    {(phone || email) && (
      <div class="mt-4 pt-4 border-t border-earth-100 space-y-1 text-sm text-earth-700">
        {phone && <span class="block">{phone}</span>}
        {email && <span class="block truncate">{email}</span>}
      </div>
    )}
  </div>
</a>
