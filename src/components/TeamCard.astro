---
import type { TeamMember } from '../data/team';

interface Props {
  member: TeamMember;
}

const { member } = Astro.props;
const photo = member.photo || member.remotePhoto;
---

<a
  href={`/about/team/${member.slug}`}
  class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl hover:shadow-navy-900/8 transition-all duration-500 border border-warm-200/50 flex flex-col"
>
  <div class="aspect-[4/5] overflow-hidden bg-warm-100">
    {photo ? (
      <img
        src={photo}
        alt={member.name}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center text-navy-300">
        <svg class="w-24 h-24" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
      </div>
    )}
  </div>
  <div class="p-6 flex-1 flex flex-col">
    <h3 class="font-serif text-xl font-semibold text-navy-900 group-hover:text-gold-700 transition-colors">
      {member.name}
    </h3>
    <p class="text-gold-600 text-sm font-medium tracking-wide mt-1">{member.role}</p>
    <p class="text-navy-500 text-sm mt-3 line-clamp-3 flex-1">{member.bio}</p>
    <div class="mt-4 pt-4 border-t border-warm-200/60 space-y-1 text-sm">
      <a href={`tel:${member.phone.replace(/[^0-9]/g, '')}`} class="block text-navy-700 hover:text-gold-600 transition-colors">
        {member.phone}
      </a>
      {member.email && (
        <a href={`mailto:${member.email}`} class="block text-navy-700 hover:text-gold-600 transition-colors truncate">
          {member.email}
        </a>
      )}
    </div>
  </div>
</a>
