---
// Standard page header band — matches the shared 2026 design system.
// `imageUrl` is accepted for backward-compatibility but no longer used;
// the banner is a gradient band over the global topo background.
interface Props {
  label?: string;
  title: string;
  description?: string;
  imageUrl?: string;
}

const { label, title, description } = Astro.props;
---

<section class="page-banner">
  <div class="content-wrap">
    {label && <p class="section-label">{label}</p>}
    <h1 class="page-banner-title">{title}</h1>
    {description && <p class="page-banner-desc">{description}</p>}
  </div>
</section>
