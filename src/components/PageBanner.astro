---
interface Props {
  label?: string;
  title: string;
  description?: string;
  imageUrl?: string;
}

const {
  label,
  title,
  description,
  imageUrl = 'https://reappdata.global.ssl.fastly.net/site_data/baileywrightrealty/design_assets/41c6kitchen-ideas-hbx110119wholehome-015-1572549271.jpg',
} = Astro.props;
---

<section class="relative pt-40 pb-24 overflow-hidden">
  <div class="absolute inset-0">
    <img src={imageUrl} alt="" class="w-full h-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-b from-navy-950/80 via-navy-900/70 to-navy-950/80"></div>
  </div>
  <div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-to-l from-gold-500/10 to-transparent"></div>

  <div class="relative z-10 max-w-5xl mx-auto px-6 text-center">
    {label && (
      <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-white/10 backdrop-blur-sm rounded-full text-gold-300 text-sm font-medium tracking-wide mb-6 border border-white/10">
        <span class="w-1.5 h-1.5 bg-gold-400 rounded-full"></span>
        {label}
      </div>
    )}
    <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl text-white font-medium leading-tight">
      {title}
    </h1>
    {description && (
      <p class="text-lg text-white/70 max-w-2xl mx-auto mt-6 leading-relaxed">
        {description}
      </p>
    )}
  </div>
</section>
