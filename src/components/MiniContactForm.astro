---
import { formIds } from '../data/forms';

interface Props {
  heading?: string;
  description?: string;
  variant?: 'light' | 'dark';
  /** Office neighborhood UUID — records contact interest + routes the lead to the neighborhood team. */
  neighborhoodId?: string | null;
  /** Office listing UUID — records contact interest + routes the lead to the listing agent. */
  listingId?: string | null;
}

const {
  heading = "Questions? We'd Love to Hear from You",
  description = 'Whether you\'re buying, selling, or just exploring your options, our team is here to help. Reach out and let us put our decades of experience to work for you.',
  variant = 'light',
  neighborhoodId = null,
  listingId = null,
} = Astro.props;

const formId = formIds.contact;
---

<section class={`py-24 lg:py-32 ${variant === 'dark' ? 'bg-navy-900 text-white' : ''}`}>
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16">
      <div>
        <div class={`${variant === 'dark' ? 'text-gold-400' : 'text-gold-600'} font-medium text-sm tracking-widest uppercase mb-3`}>
          Contact
        </div>
        <h2 class={`font-serif text-3xl md:text-4xl ${variant === 'dark' ? 'text-white' : 'text-navy-900'} font-medium mb-6 leading-snug`}>
          {heading}
        </h2>
        <p class={`${variant === 'dark' ? 'text-navy-300' : 'text-navy-500'} leading-relaxed mb-8`}>
          {description}
        </p>

        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class={`w-12 h-12 rounded-xl ${variant === 'dark' ? 'bg-gold-500/20' : 'bg-gold-50'} text-gold-${variant === 'dark' ? '400' : '600'} flex items-center justify-center shrink-0`}>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            </div>
            <div>
              <div class={`font-semibold ${variant === 'dark' ? 'text-white' : 'text-navy-900'} mb-1`}>Phone</div>
              <a href="tel:919-847-7140" class={`${variant === 'dark' ? 'text-navy-300' : 'text-navy-500'} hover:text-gold-${variant === 'dark' ? '400' : '600'} transition-colors`}>(919) 847-7140</a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class={`w-12 h-12 rounded-xl ${variant === 'dark' ? 'bg-gold-500/20' : 'bg-gold-50'} text-gold-${variant === 'dark' ? '400' : '600'} flex items-center justify-center shrink-0`}>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <div>
              <div class={`font-semibold ${variant === 'dark' ? 'text-white' : 'text-navy-900'} mb-1`}>Email</div>
              <a href="mailto:info@juliewrightrealtygroup.com" class={`${variant === 'dark' ? 'text-navy-300' : 'text-navy-500'} hover:text-gold-${variant === 'dark' ? '400' : '600'} transition-colors`}>info@juliewrightrealtygroup.com</a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class={`w-12 h-12 rounded-xl ${variant === 'dark' ? 'bg-gold-500/20' : 'bg-gold-50'} text-gold-${variant === 'dark' ? '400' : '600'} flex items-center justify-center shrink-0`}>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <div>
              <div class={`font-semibold ${variant === 'dark' ? 'text-white' : 'text-navy-900'} mb-1`}>Office</div>
              <p class={variant === 'dark' ? 'text-navy-300' : 'text-navy-500'}>10931 Strickland Rd, Ste 111<br />Raleigh, NC 27615</p>
            </div>
          </div>
        </div>
      </div>

      <div class={`${variant === 'dark' ? 'bg-white/5 border-white/10 backdrop-blur-sm' : 'bg-white border-warm-200/50'} rounded-2xl p-8 md:p-10 shadow-lg shadow-navy-900/5 border`}>
        <h3 class={`font-serif text-xl ${variant === 'dark' ? 'text-white' : 'text-navy-900'} font-semibold mb-6`}>Send Us a Message</h3>
        <form
          class="space-y-5"
          data-mini-contact
          data-form-id={formId ?? ''}
        >
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="mc-name" class={`block text-sm font-medium ${variant === 'dark' ? 'text-white/80' : 'text-navy-700'} mb-1.5`}>Name *</label>
              <input
                type="text"
                id="mc-name"
                name="name"
                required
                class={`w-full px-4 py-3 rounded-lg border ${variant === 'dark' ? 'bg-white/10 border-white/20 text-white placeholder-white/40' : 'border-warm-200 text-navy-900 placeholder-navy-300'} focus:outline-none focus:ring-2 focus:ring-gold-500/30 focus:border-gold-500 transition-all`}
                placeholder="Your full name"
              />
            </div>
            <div>
              <label for="mc-phone" class={`block text-sm font-medium ${variant === 'dark' ? 'text-white/80' : 'text-navy-700'} mb-1.5`}>Phone *</label>
              <input
                type="tel"
                id="mc-phone"
                name="phone"
                required
                class={`w-full px-4 py-3 rounded-lg border ${variant === 'dark' ? 'bg-white/10 border-white/20 text-white placeholder-white/40' : 'border-warm-200 text-navy-900 placeholder-navy-300'} focus:outline-none focus:ring-2 focus:ring-gold-500/30 focus:border-gold-500 transition-all`}
                placeholder="(XXX) XXX-XXXX"
              />
            </div>
          </div>
          <div>
            <label for="mc-email" class={`block text-sm font-medium ${variant === 'dark' ? 'text-white/80' : 'text-navy-700'} mb-1.5`}>Email *</label>
            <input
              type="email"
              id="mc-email"
              name="email"
              required
              class={`w-full px-4 py-3 rounded-lg border ${variant === 'dark' ? 'bg-white/10 border-white/20 text-white placeholder-white/40' : 'border-warm-200 text-navy-900 placeholder-navy-300'} focus:outline-none focus:ring-2 focus:ring-gold-500/30 focus:border-gold-500 transition-all`}
              placeholder="your@email.com"
            />
          </div>
          <div>
            <label for="mc-message" class={`block text-sm font-medium ${variant === 'dark' ? 'text-white/80' : 'text-navy-700'} mb-1.5`}>Message *</label>
            <textarea
              id="mc-message"
              name="message"
              rows="4"
              required
              class={`w-full px-4 py-3 rounded-lg border ${variant === 'dark' ? 'bg-white/10 border-white/20 text-white placeholder-white/40' : 'border-warm-200 text-navy-900 placeholder-navy-300'} focus:outline-none focus:ring-2 focus:ring-gold-500/30 focus:border-gold-500 transition-all resize-none`}
              placeholder="How can we help you?"
            ></textarea>
          </div>
          <input type="text" name="website" tabindex="-1" autocomplete="off" class="sr-only" aria-hidden="true" />
          {neighborhoodId && <input type="hidden" name="neighborhood_id" value={neighborhoodId} />}
          {listingId && <input type="hidden" name="listing_id" value={listingId} />}
          <p class={`${variant === 'dark' ? 'text-navy-400' : 'text-navy-400'} text-xs leading-relaxed`}>
            By submitting this form, you are giving Julie Wright Realty Group permission to contact you via email, phone, or text.
          </p>
          <button
            type="submit"
            class="w-full py-3.5 bg-gold-500 hover:bg-gold-600 text-white font-semibold rounded-lg transition-all duration-300 hover:shadow-lg hover:shadow-gold-500/25"
          >
            Send Message
          </button>
          <p data-form-status class="text-sm hidden"></p>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  import { submitForm } from '../lib/api';

  document.querySelectorAll<HTMLFormElement>('form[data-mini-contact]').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const status = form.querySelector<HTMLElement>('[data-form-status]');
      const button = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      if (!button || !status) return;

      button.disabled = true;
      const originalText = button.textContent;
      button.textContent = 'Sending…';
      status.classList.add('hidden');

      const formId = form.dataset.formId || null;
      const data = Object.fromEntries(new FormData(form).entries());
      const result = await submitForm(formId, data);

      status.classList.remove('hidden');
      status.textContent = result.message;
      status.className = result.ok
        ? 'text-sm text-green-700'
        : 'text-sm text-red-600';

      button.disabled = false;
      button.textContent = originalText;
      if (result.ok) form.reset();
    });
  });
</script>
