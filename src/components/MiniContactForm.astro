---
import { formIds } from '../data/forms';
import { site } from '../data/site';

interface Props {
  heading?: string;
  description?: string;
  variant?: 'light' | 'dark';
}

const {
  heading = "Questions? We'd Love to Hear from You",
  description = "Whether you're buying, selling, or just exploring your options, our team is here to help. Reach out and let us put four decades of experience to work for you.",
} = Astro.props;

const formId = formIds.contact;
---

<section class="py-12 lg:py-16 relative">
  <div class="content-wrap">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">
      <!-- Info -->
      <div>
        <p class="section-label">Contact</p>
        <h2 class="section-heading">{heading}</h2>
        <p class="text-earth-600 leading-relaxed mt-4 mb-8">{description}</p>

        <div class="space-y-5">
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-sm bg-earth-100 text-red-600 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            </div>
            <div>
              <div class="font-display text-earth-900">Phone</div>
              <a href={`tel:${site.phoneRaw}`} class="text-earth-600 hover:text-red-600 transition-colors">{site.phone}</a>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-sm bg-earth-100 text-red-600 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <div>
              <div class="font-display text-earth-900">Email</div>
              <a href={`mailto:${site.email}`} class="text-earth-600 hover:text-red-600 transition-colors">{site.email}</a>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-sm bg-earth-100 text-red-600 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <div>
              <div class="font-display text-earth-900">Office</div>
              <p class="text-earth-600">{site.address.street1}, {site.address.street2}<br />{site.address.city}, {site.address.state} {site.address.zip}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Form -->
      <div class="bg-white rounded-sm p-8 md:p-10">
        <h3 class="contact-form-heading">Send Us a Message</h3>
        <form class="form-stack" data-mini-contact data-form-id={formId ?? ''}>
          <div class="form-row-2">
            <div>
              <label for="mc-name" class="form-label">Name *</label>
              <input type="text" id="mc-name" name="name" required class="form-input" placeholder="Your full name" />
            </div>
            <div>
              <label for="mc-phone" class="form-label">Phone *</label>
              <input type="tel" id="mc-phone" name="phone" required class="form-input" placeholder="(XXX) XXX-XXXX" />
            </div>
          </div>
          <div>
            <label for="mc-email" class="form-label">Email *</label>
            <input type="email" id="mc-email" name="email" required class="form-input" placeholder="your@email.com" />
          </div>
          <div>
            <label for="mc-message" class="form-label">Message *</label>
            <textarea id="mc-message" name="message" rows="4" required class="form-textarea" placeholder="How can we help you?"></textarea>
          </div>
          <input type="text" name="website" tabindex="-1" autocomplete="off" class="sr-only" aria-hidden="true" />
          <p class="text-earth-400 text-xs leading-relaxed">
            By submitting this form, you are giving {site.name} permission to contact you via email, phone, or text.
          </p>
          <button
            type="submit"
            class="w-full py-3 font-display font-medium border-2 border-red-600 bg-red-600 text-earth-50 tracking-wide rounded-sm transition-all duration-300 hover:bg-red-700 hover:border-red-700 cursor-pointer"
          >
            Send Message
          </button>
          <p data-form-status class="text-sm hidden"></p>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  import { submitForm } from '../lib/api';

  document.querySelectorAll<HTMLFormElement>('form[data-mini-contact]').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const status = form.querySelector<HTMLElement>('[data-form-status]');
      const button = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      if (!button || !status) return;

      button.disabled = true;
      const originalText = button.textContent;
      button.textContent = 'Sending…';
      status.classList.add('hidden');

      const formId = form.dataset.formId || null;
      const data = Object.fromEntries(new FormData(form).entries());
      const result = await submitForm(formId, data);

      status.classList.remove('hidden');
      status.textContent = result.message;
      status.className = result.ok ? 'text-sm text-red-700' : 'text-sm text-red-600';

      button.disabled = false;
      button.textContent = originalText;
      if (result.ok) form.reset();
    });
  });
</script>
